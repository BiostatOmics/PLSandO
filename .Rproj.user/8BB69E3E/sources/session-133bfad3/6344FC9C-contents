      if(class(weightsStar)[1]=='try-error') weightsStar = mypls$weights[,1:j,drop=FALSE]%*%(corpcor::pseudoinverse(crossprod(mypls$loadings[,1:j,drop=FALSE], mypls$weights[,1:j,drop=FALSE])))
      coefficients = tcrossprod(weightsStar, mypls$loadingsY[,1:j,drop=FALSE])
