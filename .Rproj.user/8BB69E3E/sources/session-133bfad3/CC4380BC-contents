validationPlot = function(x, col = col){

  R = x$input$perm

  pR2Y = sum(x$validation$R2 > x$summary$cumR2Y[x$ncomp])/ R
  pQ2 = ifelse(x$summary$cumQ2[x$ncomp] > 0, (sum(x$validation$Q2 > x$summary$cumQ2[x$ncomp]) + sum(x$validation$Q2 < -x$summary$cumQ2[x$ncomp]) )/ R, (sum(x$validation$Q2 < x$summary$cumQ2[x$ncomp]) + sum(x$validation$Q2 > -x$summary$cumQ2[x$ncomp])) / R)

  validation_long = data.frame(
    Similarity = rep(x$validation$Similarity, 2),
    Metric     = rep(c("R2", "Q2"), each = nrow(x$validation)),
    Value      = c(x$validation$R2, x$validation$Q2)
  )

  R2 = x$summary$cumR2Y[x$ncomp]
  Q2 = x$summary$cumQ2[x$ncomp]

  if ((length(col) == 1 && !(col %in% c('main', 'complete', 'cblindfriendly', 'sunshine','hot','warm','grass','oficial'))) || length(col)>1){
    if (length(col)!= 2) return(stop('Either provide 2 colors or use one of the default color palettes'))
    custom_colors = setNames(col, unique(validation_long$Metric))
  } else{
    color_palette = colorbiostat(3, palette = col)
    custom_colors = setNames(color_palette[-2], unique(validation_long$Metric))
  }

  ggp = ggplot(validation_long, aes(x = Similarity, y = Value, color = Metric)) +
    geom_point(size = 3) +
    scale_color_manual(values = custom_colors) +
    geom_hline(yintercept = R2, color = custom_colors[1], linetype = "dashed") +
