f1s = function(t, epsilon){

  precision = t[2,2] / (t[2,2]+t[1,2]+epsilon)
  recall = t[2,2] / (t[2,2]+t[2,1]+epsilon)
  return((2*precision*recall)/(precision+recall+epsilon))

}

MCCs = function(t, epsilon) {
  numerator = (t[1,1] * t[2,2]) - (t[1,2] * t[2,1])
  denominator = sqrt((t[2,2] + t[1,2]) * (t[2,2] + t[2,1]) * (t[1,1] + t[1,2]) * (t[1,1] + t[2,1])) + epsilon
  return(numerator / denominator)
}

createFold_plsda = function(X, Y, k, seed = NULL){

  if(!is.null(seed)) set.seed(seed)

  n = nrow(X)
  group_indices = split(1:n,Y)

  indices = lapply(group_indices, sample)

  indices = unlist(do.call(mapply, c(FUN = c, indices, SIMPLIFY = FALSE)))

  folds = vector('list', k)
  assignment = rep(1:k, length.out = length(indices))

  for (i in seq_along(indices)) {
    folds[[assignment[i]]] = c(folds[[assignment[i]]], indices[i])
  }

  return(folds)
}

