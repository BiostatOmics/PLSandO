# Data preparation for PCA and PLS ----------------------------------------

dummytovariable = function(mat,name){

  var = matrix(0,nrow = nrow(mat),ncol = 1)
  colnames(var) = name

  for (i in 1:ncol(mat)){
    var[which(mat[,i]==max(mat[,i]))] = gsub(paste0(name,'_'), '',colnames(mat)[i])
  }

  var = as.factor(var)
  return(var)
}

remove_NA = function(x, excludeNA= 0.2, removed_vars= removed_vars){

  removed_obs = data.frame('Observation' = character(), 'Problem' = numeric())

  p_miss = naniar::prop_miss_row(x) # Por observación
  p_miss_vars = naniar::miss_var_summary(x) # Por variable
  obs = which(p_miss>=excludeNA)
  vars =which(p_miss_vars$pct_miss>=excludeNA*100)
  while (length(obs>0) | length(vars>0)) {

    p_obs = as.numeric(max(names(table(p_miss))))
    p_vars = as.numeric(p_miss_vars$pct_miss[1])/100

    if(p_obs> p_vars){

      thres = max(excludeNA ,p_obs - ((p_obs - excludeNA)/10))
      obs = rownames(x)[which(p_miss<thres)]
      rem = setdiff(rownames(x), obs)
      removed_obs <- rbind(removed_obs, data.frame('Observation' = rem, 'Problem' = paste(as.character(round(p_miss[which(p_miss>=thres)], digits = 2)*100), "% of NAs", sep='')))
      x =  x[obs,, drop=FALSE]
    } else {
      thres = max(excludeNA ,p_vars - ((p_vars - excludeNA)/10))
      vars = p_miss_vars$variable[which((p_miss_vars$pct_miss)/100<thres)]
      rem = setdiff(colnames(x), vars)
      p_miss_vars = p_miss_vars[p_miss_vars$variable %in% rem, c("variable", "pct_miss")]

      removed_vars$Problem = ifelse(removed_vars$Variable %in% rem,
                                    paste(as.character(round(as.numeric(p_miss_vars$pct_miss[match(removed_vars$Variable, p_miss_vars$variable)]),digits = 2)), "% of NAs", sep = '') ,"")

      removed_vars$Model = ifelse(removed_vars$Variable %in% rem,
                                  "Excluded" ,"")
      x = x[,vars, drop=FALSE]
    }

    p_miss = naniar::prop_miss_row(x) # Por observación
    p_miss_vars = naniar::miss_var_summary(x) # Por variable
    obs = which(p_miss>=excludeNA)
    vars = which(p_miss_vars$pct_miss>=excludeNA*100)

  }


  return(list(x = x, removed_obs = removed_obs, removed_vars = removed_vars))
}

prepare_x = function(df, includeFactors = TRUE, removed_vars){

  rownam = rownames(df)

  df = lapply(names(df), function(col){

    x = df[[col]]

    if ((is.factor(x) || is.logical(x) || is.character(x))){
      if(includeFactors){
        x = factor(x, exclude = NULL)
        x1 = model.matrix(~0+., data = data.frame(x))
        if(any(is.na(as.character(x)=='NA'))){
          x1[is.na(as.character(x)=='NA')] = NA
          x1 = x1[,-ncol(x1), drop=FALSE] #Remove column associated to NAs
        }
        tab = table(x, useNA = "ifany")  # Remove NA as level
        colnames(x1) = paste(col,names(tab)[!is.na(names(tab))], sep ='_')
        removed_vars[which(removed_vars$Variable==col),c(2,3)] <<- c("Modified","Factor type variable converted to dummy")
        return(as.list(as.data.frame(x1)))
      } else{
        removed_vars[which(removed_vars$Variable==col),c(2,3)] <<- c("Excluded","Factor type variable not converted to dummy")
        return(NULL)
      }
    }
    return(setNames(list(x), col))
  })

  df = as.data.frame(do.call(c, df))
  rownames(df) = rownam
  return(list(x = df, removed_vars = removed_vars))
}

remove_CV = function(x, CVfilter = 0.01, removed_vars){

  cv = lapply(x, function(x){
    meanx = mean(x, na.rm = T)
    sdx = sd(x, na.rm = T)
    return(abs(sdx/meanx))
  }) #Dejarlo en valor absoluto

  keep = names(cv)[cv>CVfilter]
  rem = setdiff(colnames(x), keep)
  removed_vars[which(removed_vars$Variable%in%rem),2] = "Excluded"
  removed_vars[which(removed_vars$Variable%in%rem),3] = "Low CV"

  return(list(x = x[,keep,drop=FALSE], removed_vars = removed_vars))
}

# Scaling options for PCA and PLS -----------------------------------------

Scaling = function(x, scaling, blocks = NULL) {

  if(scaling=='center'){
    x = scale(x, center = TRUE, scale = FALSE)
    escalo = rep(1, times = ncol(x))
  } else{
    x = scale(x, center = TRUE, scale = TRUE)
    escalo = attr(x, 'scaled:scale')
  }
  centro = attr(x, 'scaled:center')

  if(scaling %in% c('softBlock','hardBlock')){
    block_list = split(colnames(x), blocks)
    block_list = lapply(block_list, function(cols)  x[, cols, drop = FALSE])

    for (bl in names(block_list)) {
      X = block_list[[bl]]
      if (scaling == "softBlock") {
        X = X / (ncol(X)^0.25)
        escalo[colnames(X)] = escalo[colnames(X)]/ (ncol(X)^0.25)
      } else {
        X = X / (ncol(X)^0.5)
        escalo[colnames(X)] = escalo[colnames(X)]/ (ncol(X)^0.5)
      }
      x[,colnames(X)] = X
    }
  }
  return(list(x = x, centering = centro, scaling = escalo))
}

# Algorithms for PCA and PLS -------------------------------------------

svd_pca = function(X, ncomp = NULL){
  X = as.matrix(X)

  if(is.null(ncomp)){
    ncomp = min(nrow(X)-1, ncol(X))
  }

  temp = svd(X, nu = ncomp, nv = ncomp)
  eigen = (temp$d^2 / (nrow(X)-1)) [1:ncomp]
  scores = temp$u %*% diag(temp$d[1:ncomp])
  loadings = temp$v

  rownames(loadings) = colnames(X)
  rownames(scores) = rownames(X)
  colnames(loadings) = colnames(scores) = paste0('p',1:ncomp)

  return(list(scores=scores, loadings = loadings, eigen = eigen))
}

nipals_pca = function(X, ncomp = NULL ){

  X = as.matrix(X)

  if(any(is.na(X))){
    missNA = T
    X_sinNA = X
    X_sinNA[is.na(X)]= 0
    C = matrix(1, ncol = ncol(X), nrow = nrow(X) )
    C[is.na(X)] = 0
  }  else missNA = F

  if(is.null(ncomp)){
    ncomp = min(nrow(X)-1, ncol(X))
  }

  scores = matrix(0,nrow = nrow(X),ncol =ncomp )
  loadings = matrix(0, nrow = ncol(X), ncol = ncomp )
  eigen = rep(0, ncomp)

  for (i in 1:ncomp) {
    iter = 1
    p_old = rep(0, ncol(X))
    #Initiate the scores with the variable with the highest variance when there are no NAs with the one with least NAs instead
    if(missNA){
      t_old = X[,1,drop=FALSE]
      t_old[is.na(t_old)] = 0
    } else t_old = X[,which.max(apply(X,2,var))[[1]],drop=FALSE]

    p_new = if(missNA) crossprod(X_sinNA, t_old) / (t(C) %*% t_old^2)  else crossprod(X, t_old)/drop(crossprod(t_old))

    #Normalize p_new to unit length
    p_new = p_new / sqrt(drop(crossprod(p_new)))

    t_new = if(missNA) (X_sinNA %*% p_new) / C %*% p_new^2   else X %*% p_new

    while (sqrt(drop(crossprod(p_new-p_old)))>1e-6 && iter<100) {
      #Update
      t_old = t_new
      p_old = p_new
      iter = iter + 1

      #Recalculate T and P
      p_new = if(missNA) crossprod(X_sinNA, t_old) / (t(C) %*% t_old^2) else crossprod(X, t_old)/drop(crossprod(t_old))
      #Normalize p_new to unit length
      p_new = p_new / sqrt(drop(crossprod(p_new)))
      t_new = if(missNA) (X_sinNA %*% p_new) / C %*% p_new^2   else X %*% p_new
    }
    loadings[,i] = p_new
    scores[,i] = t_new
    eigen[i] = crossprod(t_new) / (nrow(X)-1)

    X = X - tcrossprod(t_new, p_new)

    if(missNA){
      X_sinNA = X
      X_sinNA[is.na(X)]= 0
    }

  }
  rownames(loadings) = colnames(X)
  rownames(scores) = rownames(X)
  colnames(loadings) = colnames(scores) = paste0('p',1:ncomp)

  return(list(scores=scores, loadings = loadings, eigen = eigen))
}

nipals_mbpca = function(X, ncomp = NULL ){

  b_names = names(X)

  block_weight = matrix(0,nrow = length(X),ncol =ncomp )
  super_scores = matrix(0, nrow = nrow(X[[1]]), ncol = ncomp )
  super_loadings = matrix(0, nrow = length(X), ncol = ncomp )
  eigen = rep(0, ncomp)

  tr = setNames(lapply(b_names, function(x) sum(diag(t(X[[x]])%*%X[[x]]))),b_names)

  for (i in 1:ncomp){

    iter = 1
    w_old = rep(0, length(X))

    #Choose an arbitrary starting global score
    rand = X[[sample(length(X), 1)]]
    super_t_old = rand[, sample(ncol(rand), 1), drop=FALSE]

    block_p = setNames(lapply(b_names, function(x) crossprod(X[[x]], super_t_old) / drop(crossprod(super_t_old))), b_names)
    block_p = setNames(lapply(b_names, function(x) block_p[[x]] / sqrt(drop(crossprod(block_p[[x]])))), b_names)
    block_t = setNames(lapply(b_names, function(x) (X[[x]] %*% block_p[[x]])/sqrt(ncol(X[[x]]))), b_names)

    T_scores = do.call(cbind, block_t)
    w_new = crossprod(T_scores, super_t_old) / drop(crossprod(super_t_old))
    w_new = w_new / sqrt(drop(crossprod(w_new)))

    super_t_new = T_scores %*% w_new

    while(sqrt(drop(crossprod(w_new-w_old)))>1e-6 && iter<100){

      #Update
      super_t_old = super_t_new
      w_old = w_new
      iter = iter + 1

      #Recalculate block_scores, loadings, super_scores and loadings
      block_p = setNames(lapply(b_names, function(x) crossprod(X[[x]], super_t_old) / drop(crossprod(super_t_old))), b_names)
      block_p = setNames(lapply(b_names, function(x) block_p[[x]] / sqrt(drop(crossprod(block_p[[x]])))), b_names)
      block_t = setNames(lapply(b_names, function(x) (X[[x]] %*% block_p[[x]])/sqrt(ncol(X[[x]]))), b_names)

      T_scores = do.call(cbind, block_t)
      w_new = crossprod(T_scores, super_t_old) / drop(crossprod(super_t_old))
      w_new = w_new / sqrt(drop(crossprod(w_new)))

      super_t_new = T_scores %*% w_new
    }

    if (i==1){
      block_scores = block_t
      block_loadings = block_p
    } else{
      block_scores = setNames(lapply(b_names, function(x) cbind(block_scores[[x]], block_t[[x]])),b_names)
      block_loadings = setNames(lapply(b_names, function(x) cbind(block_loadings[[x]], block_p[[x]])),b_names)
    }

    super_scores[,i] = super_t_new
    super_loadings[,i] = w_new
    eigen[i] = crossprod(super_t_new) / (nrow(X[[1]])-1)

    X = setNames(lapply(b_names, function(x) X[[x]]- tcrossprod(super_t_new, block_p[[x]])),b_names)

    Eb = setNames(lapply(b_names, function(x) sum(diag(t(X[[x]])%*%X[[x]]))),b_names)
    explvarB = if(i==1)  setNames(lapply(b_names, function(x) (1-Eb[[x]]/tr[[x]])*100) ,b_names) else setNames(lapply(b_names, function(x) cbind(explvarB[[x]],(1-Eb[[x]]/tr[[x]])*100)) ,b_names)

  }

  #Change the colnames and save the rownames
  block_scores = lapply(block_scores, function(x) {
    colnames(x) = paste0("p", 1:ncomp)
    rownames(x) = rownames(X[[1]])
    return(x)
  })

  block_loadings = lapply(names(block_loadings), function(x) {
    colnames(block_loadings[[x]]) = paste0("p", 1:ncomp)
    rownames(block_loadings[[x]]) = colnames(X[[x]])
    return(block_loadings[[x]])
  })
  names(block_loadings) = b_names

  colnames(super_loadings) = colnames(super_scores) = paste0("p", 1:ncomp)
  rownames(super_loadings) = b_names
  rownames(super_scores) = rownames(X[[1]])

  return(list(block_scores=block_scores, block_loadings = block_loadings, super_scores = super_scores,super_loadings= super_loadings, eigen = eigen, explvarB = explvarB))
}

nipals_pls = function(X, Y, ncomp = NULL ){

  X = as.matrix(X)
  Y = as.matrix(Y)

  if(any(is.na(X))||any(is.na(Y))){
    missNA =  T
    X_sinNA = X
    X_sinNA[is.na(X)]= 0
    C = matrix(1, ncol = ncol(X), nrow = nrow(X) )
    C[is.na(X)] = 0
    if(any(is.na(Y))) missNAY = T else missNAY = F
    Y_sinNA = Y
    Y_sinNA[is.na(Y)]= 0
    CY = matrix(1, ncol = ncol(Y), nrow = nrow(Y) )
    CY[is.na(Y)] = 0
  }  else missNA = F; missNAY = F

  if(is.null(ncomp)){
    ncomp = min(nrow(X)-1, ncol(X))
  }

  scores = matrix(0,nrow = nrow(X),ncol =ncomp )
  loadings = matrix(0, nrow = ncol(X), ncol = ncomp )
  scoresY = matrix(0,nrow = nrow(X),ncol =ncomp )
  loadingsY = matrix(0, nrow = ncol(Y), ncol = ncomp )
  weights = matrix(0, nrow = ncol(X), ncol = ncomp )

  for (i in 1:ncomp) {
    iter = 1
    #Initiate the scores with the variable with the highest variance when there are no NAs with the one with least NAs instead
    if(missNAY){
      u_old = Y[,1,drop=FALSE]
      u_old[is.na(u_old)] = 0
    } else u_old = Y[,which.max(apply(Y,2,var))[[1]],drop=FALSE]

    w_new = if(missNA) crossprod(X_sinNA, u_old)/drop(t(CY) %*% u_old^2) else crossprod(X, u_old)/drop(crossprod(u_old))
    w_new = w_new / sqrt(drop(crossprod(w_new)))

    t_new = if(missNA) (X_sinNA %*% w_new) / (C %*% w_new^2)  else X %*% w_new

    c_new = if(missNA)  crossprod(Y_sinNA, t_new) / (t(CY) %*% t_new^2)  else crossprod(Y, t_new)/drop(crossprod(t_new))

    u_new = if(missNA) if(ncol(CY)==1) (Y_sinNA %*% c_new) / drop(t(c_new)%*%c_new) else (Y_sinNA %*% c_new) / (CY %*% c_new^2)  else (Y %*% c_new) / drop(crossprod(c_new))

    p_new = if(missNA)  crossprod(X_sinNA, t_new)/(t(C) %*% t_new^2)  else crossprod(X, t_new)/drop(crossprod(t_new))

    while (sqrt(drop(crossprod(u_new-u_old)))>1e-6 && iter<100) {
      #Update
      t_old = t_new
      p_old = p_new
      c_old = c_new
      u_old = u_new
      iter = iter + 1

      #Recalculate T, P, W, U and C
      w_new = if(missNA) crossprod(X_sinNA, u_old) / drop(t(CY) %*% u_old^2) else crossprod(X, u_old)/drop(crossprod(u_old))
      w_new = w_new / sqrt(drop(crossprod(w_new)))

      t_new = if(missNA) (X_sinNA %*% w_new) / (C %*% w_new^2)  else X %*% w_new

      c_new = if(missNA) crossprod(Y_sinNA, t_new) / (t(CY) %*% t_new^2)  else crossprod(Y, t_new)/drop(crossprod(t_new))

      u_new = if(missNA) if(ncol(CY)==1) (Y_sinNA %*% c_new) / drop(t(c_new)%*%c_new) else (Y_sinNA %*% c_new) / (CY %*% c_new^2)  else (Y %*% c_new) / drop(crossprod(c_new))

      p_new = if(missNA) crossprod(X_sinNA, t_new) / (t(C) %*% t_new^2)  else  crossprod(X, t_new)/drop(crossprod(t_new))

    }
    loadings[,i] = p_new
    scores[,i] = t_new
    loadingsY[,i] = c_new
    scoresY[,i] = u_new
    weights[,i] = w_new

    X = X - tcrossprod(t_new,p_new)
    Y = Y - tcrossprod(t_new,c_new)

    if(missNA){
      X_sinNA = X
      X_sinNA[is.na(X)]= 0
      Y_sinNA = Y
      Y_sinNA[is.na(Y)]= 0
    }

  }

  weightsStar = weights%*%solve(crossprod(loadings, weights))

  coefficients = tcrossprod(weightsStar, loadingsY)

  rownames(loadings) = rownames(weights) = rownames(weightsStar) = rownames(coefficients) = colnames(X)
  rownames(loadingsY) = colnames(coefficients) = colnames(Y)
  rownames(scores) = rownames(scoresY) = rownames(X)
  colnames(loadings) = colnames(scores)= colnames(scoresY)= colnames(loadingsY)= colnames(weights) = colnames(weightsStar) = paste0('p',1:ncomp)

  return(list(scores=scores, loadings = loadings, scoresY=scoresY, loadingsY = loadingsY, weights = weights, weightsStar = weightsStar, coefficients = coefficients ))
}

nipals_mbpls = function(X, Y, ncomp = NULL ){

  b_names = names(X)

  X = lapply(X, as.matrix)
  Y = as.matrix(Y)

  block_weight = matrix(0, nrow = length(X),ncol = ncomp )
  super_scores = matrix(0, nrow = nrow(X[[1]]), ncol = ncomp )

  scoresY = matrix(0,nrow = nrow(X[[1]]), ncol = ncomp )
  loadingsY = matrix(0, nrow = ncol(Y), ncol = ncomp )
  weights = matrix(0, nrow = length(b_names), ncol = ncomp )

  block_coef = setNames(lapply(seq_along(X), function(b) array(0, dim = c(ncol(X[[b]]), ncol(Y), ncomp))),b_names)

  tr = setNames(lapply(b_names, function(x) sum(diag(t(X[[x]])%*%X[[x]]))),b_names)

  for (i in 1:ncomp) {
    iter = 1
    #Initiate the scores with the variable with the highest variance. U pertenece siempre al super level
    u_old = Y[,which.max(apply(Y,2,var))[[1]],drop=FALSE]

    block_w = setNames(lapply(b_names, function(x) crossprod(X[[x]],u_old) / drop(crossprod(u_old))), b_names)
    block_w = setNames(lapply(b_names, function(x) block_w[[x]] / sqrt(drop(crossprod(block_w[[x]])))), b_names)
    block_t = setNames(lapply(b_names, function(x) (X[[x]] %*% block_w[[x]])/sqrt(ncol(X[[x]]))), b_names)

    T_scores = do.call(cbind, block_t)
    w_new = crossprod(T_scores, u_old) / drop(crossprod(u_old))
    w_new = w_new / sqrt(drop(crossprod(w_new)))

    t_new = T_scores %*% w_new / drop(crossprod(w_new))
    c_new = crossprod(Y, t_new) / drop(crossprod(t_new))
    u_new = (Y %*% c_new) / drop(crossprod(c_new))

    while (sqrt(drop(crossprod(u_new-u_old)))>1e-6 && iter<100) {
      #Update
      t_old = t_new
      c_old = c_new
      u_old = u_new
      iter = iter + 1

      #Recalculate T, P, W, U and C
      block_w = setNames(lapply(b_names, function(x) crossprod(X[[x]],u_old) / drop(crossprod(u_old))), b_names)
      block_w = setNames(lapply(b_names, function(x) block_w[[x]] / sqrt(drop(crossprod(block_w[[x]])))), b_names)
      block_t = setNames(lapply(b_names, function(x) (X[[x]] %*% block_w[[x]])/sqrt(ncol(X[[x]]))), b_names)

      T_scores = do.call(cbind, block_t)
      w_new = crossprod(T_scores, u_old) / drop(crossprod(u_old))
      w_new = w_new / sqrt(drop(crossprod(w_new)))

      t_new = T_scores %*% w_new / drop(crossprod(w_new))
      c_new = crossprod(Y, t_new) / drop(crossprod(t_new))
      u_new = (Y %*% c_new) / drop(crossprod(c_new))

    }

    block_p = setNames(lapply(b_names, function(x) crossprod(X[[x]], t_new) / drop(crossprod(t_new))), b_names)

    if (i==1){
      block_scores = block_t
      block_weight = block_w
      block_loading = block_p
    } else{
      block_scores = setNames(lapply(b_names, function(x) cbind(block_scores[[x]], block_t[[x]])),b_names)
      block_weight = setNames(lapply(b_names, function(x) cbind(block_weight[[x]], block_w[[x]])),b_names)
      block_loading = setNames(lapply(b_names, function(x) cbind(block_loading[[x]], block_p[[x]])),b_names)
    }

    super_scores[,i] = t_new

    X = setNames(lapply(b_names, function(x) X[[x]]- tcrossprod(t_new, block_p[[x]])),b_names)
    Y = Y - tcrossprod(t_new,c_new)

    Eb = setNames(lapply(b_names, function(x) sum(diag(t(X[[x]])%*%X[[x]]))),b_names)
    explvarB = if(i==1)  setNames(lapply(b_names, function(x) (1-Eb[[x]]/tr[[x]])*100) ,b_names) else setNames(lapply(b_names, function(x) cbind(explvarB[[x]],(1-Eb[[x]]/tr[[x]])*100)) ,b_names)

    loadingsY[,i] = c_new
    scoresY[,i] = u_new
    weights[,i] = w_new

    T_composite = do.call('+',lapply(seq_along(b_names), function(x) w_new[x]*block_t[[x]]))
    coef = crossprod(T_composite, u_new)/drop(crossprod(T_composite))
    for (b in 1:length(b_names)) {
      block_coef[[b]][,,i] = tcrossprod(block_w[[b]], (w_new[b] %*% coef %*% c_new))
    }
  }

  #Change the colnames and save the rownames
  block_scores = lapply(block_scores, function(x) {
    colnames(x) = paste0("p", 1:ncomp)
    rownames(x) = rownames(X[[1]])
    return(x)
  })

  block_loadings = setNames(lapply(names(block_loading), function(x) {
    colnames(block_loading[[x]]) = paste0("p", 1:ncomp)
    rownames(block_loading[[x]]) = colnames(X[[x]])
    return(block_loading[[x]])
  }), b_names)

  block_weight = setNames(lapply(names(block_weight), function(x) {
    colnames(block_weight[[x]]) = paste0("p", 1:ncomp)
    rownames(block_weight[[x]]) = colnames(X[[x]])
    return(block_weight[[x]])
  }), b_names)

  block_coef = setNames(lapply(names(block_coef), function(x) {
    rownames(block_coef[[x]]) = colnames(X[[x]])
