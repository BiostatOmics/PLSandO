    SCT = sum(Y^2)
    R2[j] = 1- (SCR/SCT)

    #PRESS
    PRESS[j] = sum((Y - Ypred)^2)

    #Q2
    Q2[j] = 1- (PRESS[j]/SCT)

    #F1
    max_cols = apply(Ypred, 1, which.max)
    ypred_bin = matrix(0,nrow = nrow(Ypred), ncol = ncol(Ypred))
    ypred_bin[cbind(1:nrow(ypred_bin), max_cols)] = 1

