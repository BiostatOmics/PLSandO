### Jack-knifed pvalues

p.jack = function(coef, coef_cv, A, alpha) {

  dims = dim(coef_cv)
  kX = dims[2]; kY = dims[3]; nCV = dims[4]
  coef_cv_a = array(0, dim = c(kX, kY, nCV))
  var_coef = CI_coef = UCI_coef = LCI_coef = pval = matrix(0, nrow = kX, ncol = kY)

  # Jack-Knife correction factor dependent on the folds
  g = (nCV - 1) / nCV

  # Critical value t-student distribution
  Tc = qt(1 - alpha/2, df = nCV)

  for (kCV in 1:nCV) {
    coef_cv_a[,,kCV] = coef_cv[A,,,kCV]
  }

  # Compute Jack-Knife confidence intervals
  for (j in 1:kY) {
    for (i in 1:kX) {

      coef_ija = coef_cv_a[i, j, ]
      var_coef[i, j] = g * sum((coef[i, j] - coef_ija)^2)
      estJK = sqrt(var_coef[i, j])
      # Compute CI
      CI_coef[i, j] = Tc * estJK
      UCI_coef[i, j] = coef[i, j] + CI_coef[i, j]
      LCI_coef[i, j] = coef[i, j] - CI_coef[i, j]

      pval[i,j] = 2*pt(abs(coef[i, j]/estJK), df = nCV, lower.tail = FALSE)

    }
  }

  return(list(
    UCI_coef = UCI_coef,
    LCI_coef = LCI_coef,
    pval = pval
  ))
}

JK = function(x, cvFolds = 5, rep = 10, threshold = 0.05, parallel = FALSE){

  res_cross = pls_cross(X = x$input$X,Y = x$input$Y,scaling = x$input$scalingType, blocks = x$input$blocks, scalingY = x$input$scalingTypeY, ncomp = x$ncomp, folds = cvFolds, rep = rep, algo = x$input$algo, parallel = parallel)

  if(x$input$algo=='nipals'){
    coef_cv = array(unlist(lapply(res_cross, `[[`, "coef_cv")),  dim = c(dim(res_cross[[1]]$coef_cv)[1:3], rep * dim(res_cross[[1]]$coef_cv)[4]))
    Jack = p.jack(x$coefficients, coef_cv, x$ncomp, threshold)

  } else{
    b_names = names(x$X)
    block_coef = lapply(x$coefficients, function(b) apply(b[,,1:x$ncomp, drop = FALSE], c(1,2), sum))
    block_coef_cv = setNames(lapply(seq_along(b_names), function(b) array(unlist(lapply(res_cross, function(r) r$block_coef_cv[[b]])), dim = c(dim(res_cross[[1]]$block_coef_cv[[1]])[1:3], dim(res_cross[[1]]$block_coef_cv[[1]])[4] * rep)) ), b_names)
    Jack = setNames(lapply(seq_along(b_names), function(b) p.jack(block_coef[[b]], block_coef_cv[[b]], x$ncomp, threshold) ), b_names)
  }
  return(Jack)
}

perm = function(x, R, threshold){
  #x: modelo PLS
  #R: número de veces a repetir la prueba

  k = x$ncomp
  Y = as.data.frame(x$Y)

  if(x$input$algo == 'nipals'){
    X = as.data.frame(x$X)
    coefmod = x$coefficients
    a = array(NA, dim=c(ncol(X),R,ncol(Y)))
    p.coefs = UCI_coef = LCI_coef = matrix(NA, nrow=ncol(X), ncol=ncol(Y))
    for (i in 1:R){
      Yperm = Y[sample(nrow(Y),replace = FALSE),,drop=FALSE]
      mypls = nipals_pls(X, Yperm, ncomp = k)
      a[,i,] = mypls$coefficients
    }
    for(i in 1:nrow(a)){
      for (j in 1:dim(a)[3]) {
        coefs = a[i,,j]
        p.coefs[i,j] = ifelse(coefmod[i,j] > 0, (sum(coefs > coefmod[i,j]) + sum(coefs < -coefmod[i,j]) )/ R, (sum(coefs < coefmod[i,j]) + sum(coefs > -coefmod[i,j])) / R)
        LCI_coef[i,j] = quantile(coefs, prob=threshold/2)
        UCI_coef[i,j] = quantile(coefs, prob=1-(threshold/2))
      }
    }
    rownames(p.coefs) = rownames(coefmod)
    colnames(p.coefs) = colnames(coefmod)

    return(list(
      UCI_coef = UCI_coef,
      LCI_coef = LCI_coef,
      pval = p.coefs ))

  }

  if(x$input$algo == 'mbpls'){
    X = x$X
    coefmod = x$coefficients_summary[,'coefficient',drop=FALSE]
    a = array(NA, dim=c(nrow(x$coefficients_summary),R,ncol(Y)))
    p.coefs = UCI_coef = LCI_coef = matrix(NA, nrow=nrow(x$coefficients_summary), ncol=ncol(Y))
    for (i in 1:R){
      Yperm = Y[sample(nrow(Y),replace = FALSE),,drop=FALSE]
      mymbpls = nipals_mbpls(X, Yperm, ncomp = k)
      block_coef = lapply(mymbpls$block_coefficients, function(b) apply(b[,,1:k, drop = FALSE], c(1,2), sum))
      a[,i,] = do.call(rbind, block_coef)
    }
    for(i in 1:nrow(a)){
      for (j in 1:dim(a)[3]) {
        coefs = a[i,,j]
        p.coefs[i,j] = ifelse(coefmod[i,j] > 0, (sum(coefs > coefmod[i,j]) + sum(coefs < -coefmod[i,j]) )/ R, (sum(coefs < coefmod[i,j]) + sum(coefs > -coefmod[i,j])) / R)
        LCI_coef[i,j] = quantile(coefs, prob=threshold/2)
        UCI_coef[i,j] = quantile(coefs, prob=1-(threshold/2))
      }
    }
    rownames(p.coefs) = rownames(coefmod)
    colnames(p.coefs) = colnames(coefmod)

    return(list(
      UCI_coef = UCI_coef,
      LCI_coef = LCI_coef,
      pval = p.coefs ))


  }

}

SMC = function(X, coefficients){

  yhat = as.matrix(X) %*% coefficients
  Xhat = tcrossprod(yhat,coefficients)/drop(crossprod(coefficients))
  Xres = X - Xhat

  SST = colSums(Xhat^2)
  SSR = colSums(Xres^2)

  #smc = SST/(SSR/(nrow(X)-2))
  smc = SST/SSR
  return(smc)
}
