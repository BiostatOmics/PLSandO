RV = function(X1, X2, X) {

  X1 = as.matrix(X1)
  X2 = as.matrix(X2)

  S1 = tcrossprod(X1)
  S2 = tcrossprod(X2)

  if(ncol(X)>nrow(X)) diag(S1) = diag(S2) = 0 #Modified RV coefficient based on Smilde et al. 2009 (better for high dimensional data)

  VcX1 = as.vector(S1)
  VcX2 = as.vector(S2)

  RV_value = crossprod(VcX1, VcX2) / sqrt(crossprod(VcX1)*crossprod(VcX2))

  return(RV_value)
}

crossForVal = function(iter, X, Y, ncomp, k = 5, scaling, scalingY, seed, method){

  if(method=='loo') k = nrow(X)

  folds = createFold(X, k, seed)

  set.seed(seed)
  Y2 = Y
  Y = Y[sample(nrow(Y)), ,drop=FALSE]

  preds = matrix(0, nrow(X), ncol(Y))

  for (i in 1:length(folds)){

    ## Scaling X

    if(class(X)!='list' && scaling %in% c('softBlock','hardBlock')) blocks = rep(1, times = ncol(X)) else blocks = NULL

    if (class(X)=='list') {
      if (!scaling %in% c("softBlock", "hardBlock")) warning('When blocks are considered we recommend using either softBlock or hardBlock scaling')
      if (length(unique(sapply(X, nrow)))!=1) return(stop('All blocks must have the same observations'))
      blocks = rep(seq_along(X), times = sapply(x, nrow) )
      X = do.call(cbind, X)
    }

    Xfold = X[-folds[[i]],,drop=FALSE]
    Yfold = Y[-folds[[i]],,drop=FALSE]

    if (scaling != 'none') {
      escalado = Scaling(Xfold, scaling= scaling, blocks = blocks)
      Xfold = escalado$x
      centrado = escalado$centering
      escalado = escalado$scaling
      Xval = sweep(X[folds[[i]],,drop=FALSE], 2, centrado, FUN = "-")
      Xval = sweep(Xval, 2, escalado, FUN = "/")
    } else{
      escalado = rep(1, times = ncol(Xfold))
      centrado = rep(0, times = ncol(Xfold))
      Xval = X[folds[[i]],,drop=FALSE]
    }

    ## Scaling Y

    if (scalingY != 'none') {
      escaladoY = Scaling(Yfold, scaling= scalingY, blocks = NULL)
      Yfold = escaladoY$x
    }

    mypls = nipals_pls(X = Xfold, Y = Yfold, ncomp = ncomp)

    preds[folds[[i]],] = as.matrix(Xval) %*% mypls$coefficients
  }

  #Calculate metrics

  if (scalingY != 'none') {
    escaladoY = Scaling(Y, scaling= scalingY, blocks = NULL)
    Y = escaladoY$x
  }

  if (scaling != 'none') {
    escalado = Scaling(X, scaling= scaling, blocks = blocks)
    X = escalado$x
  }

  plsr2 = nipals_pls(X = X, Y = Y, ncomp = ncomp)

  Ypred = preds

  #RMSE
  RMSE = sqrt((1/(nrow(X)*ncol(Y)))*sum((Y-Ypred)^2))

  #R2
  yhat = as.matrix(X) %*% plsr2$coefficients
  yhat = yhat[rownames(Y),,drop=FALSE]

  SCR = sum((Y-yhat)^2)
  SCT = sum(Y^2)
  R2 = 1- (SCR/SCT)

  #PRESS
  PRESS = sum((Y - Ypred)^2)

  #Q2
  Q2 = 1- (PRESS/SCT)

  # Similarity

  Sim = if(ncol(Y)>1) RV(Y, Y2, X) else cor(Y, Y2)

  return(list(R2=R2, Q2=Q2, PRESS=PRESS,RMSE = RMSE, Similarity = Sim))

}

