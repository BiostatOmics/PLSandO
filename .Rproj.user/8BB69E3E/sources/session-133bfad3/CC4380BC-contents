  return(list(R2=R2, Q2=Q2, PRESS=PRESS,RMSE = RMSE, Similarity = Sim))

}

plsValidation = function(X, Y, scaling, scalingY, ncomp = NULL, folds = 5 , perm = 20, algo = 'nipals', parallel = F){

  if(algo == 'nipals'){
    if(nrow(X)<=5){
      warning("Low number of replicates. Leave-one-out cv will be performed.")
      method = 'loo'
    } else method = 'kfold'
  } else {
    if(nrow(X[[1]])<=5){
      warning("Low number of replicates. Leave-one-out cv will be performed.")
      method = 'loo'
    } else method = 'kfold'
  }

  message("\n Running optimization:")


  options(future.globals.maxSize = 4000*1024^2)
  seed = 1:perm
  if(!isFALSE(parallel)){
    if(is.numeric(parallel)){
      if(.Platform$OS.type == "unix") {
        future::plan("multicore", workers = parallel)
      }else{
        future::plan("multisession", workers = parallel)
      }
    } else{
      nc = future::availableCores() - 1
      if(.Platform$OS.type == "unix") {
        future::plan("multicore", workers = nc)
      }else{
        future::plan("multisession", workers = nc)
      }
      parallel =nc
    }

    if(algo == 'nipals'){
      Val_res = furrr::future_map(1:perm,
                                  ~crossForVal(.x, X, Y, ncomp, folds, scaling, scalingY, seed[.x], method),
                                  .progress = TRUE,.options = furrr::furrr_options(seed = TRUE) )
    } else {
      Val_res = furrr::future_map(1:perm,
                                  ~crossForVal_mb(.x, X, Y, ncomp, folds, scaling, scalingY, seed[.x], method),
                                  .progress = TRUE,.options = furrr::furrr_options(seed = TRUE) )
    }


  } else{
    if(algo == 'nipals'){
      Val_res = purrr::map(1:perm,
                           ~crossForVal(.x, X, Y, ncomp, folds, scaling, scalingY, seed[.x], method),
                           .progress = TRUE,.options = furrr::furrr_options(seed = TRUE) )
    } else {
      Val_res = purrr::map(1:perm,
                           ~crossForVal_mb(.x, X, Y, ncomp, folds, scaling, scalingY, seed[.x], method),
                           .progress = TRUE,.options = furrr::furrr_options(seed = TRUE) )
    }
  }

  Val_res = do.call(rbind, lapply(Val_res, function(prm) {
    sapply(prm, function(metric) metric[1])}))

  return(Val_res)

}

# Outlier plots for PCA and PLS -------------------------------------------

# x: Object returned by pca, pls or plsda functions

T2plot = function(x, K, conf) {

  misScores = x$scores[,1:K]
  eigval = x$explVar$eigenVal[1:K]
  miT2 = colSums(t(misScores**2)/eigval)
  I = nrow(misScores)

  Flim = K*(I**2 - 1)/(I*(I - K)) * qf(conf/100, K, I-K)

  if (Flim >= max(miT2)) {

    plot(1:length(miT2), miT2, type = "l", xlab = "Observations",
         ylab = "Hotelling's T2",
         main = "Severe outliers", ylim = c(0, Flim*1.02))

  } else {

    plot(1:length(miT2), miT2, type = "l", xlab = "Observations",
         ylab = "Hotelling's T2",
         main = "Severe outliers")

  }

  abline(h = Flim, col = "red3", lty = 2, lwd = 2)

  outliers = names(which(miT2 > Flim))
  if (length(outliers) == 0) outliers = NULL

  return(list(SevereOutliers = outliers, T2 = miT2))

}



RSSplot = function(x, K, conf) {

  misScores = x$scores[,1:K]
  misLoadings = x$loadings[,1:K]
  X = x$X
  myE = X - misScores %*% t(misLoadings)
  myE[is.na(myE)] = 0
  mySCR = rowSums(myE^2)

  g = var(mySCR)/(2*mean(mySCR))
  h = (2*mean(mySCR)^2)/var(mySCR)
  chi2lim = g*qchisq(conf/100, df = h)

  if (chi2lim >= max(mySCR)) {

    plot(1:length(mySCR), mySCR, type = "l", main = "Moderate outliers",
         ylab = "Residual Sum of Squares (RSS)", xlab = "Observations",
         ylim = c(0, chi2lim*1.02))

  } else {

    plot(1:length(mySCR), mySCR, type = "l", main = "Moderate outliers",
         ylab = "Residual Sum of Squares (RSS)", xlab = "Observations")

  }

  abline(h = chi2lim, col = "red3", lty = 2, lwd = 2)

  outliers = names(which(mySCR > chi2lim))
  if (length(outliers) == 0) outliers = NULL

  return(list(ModerateOutliers = outliers, RSS = mySCR, E = myE))

}


### Contributions

contribT2 = function (X, scores, loadings, eigenval, observ, cutoff = 2) {
  # X is data matrix and must be centered (or centered and scaled if data were scaled)
  misScoresNorm = t(t(scores**2) / eigenval)
  misContrib = NULL
  for (oo in observ) {
    misPCs = which(as.numeric(misScoresNorm[oo,]) > cutoff)
    lacontri = sapply(misPCs, function (cc) (scores[oo,cc]/eigenval[cc])*loadings[,cc]*X[oo,])
    lacontri = rowSums((1*(sign(lacontri) == 1))*lacontri)
    misContrib = cbind(misContrib, lacontri)
  }
  colnames(misContrib) = rownames(misScoresNorm[observ,])
  return(misContrib)
}


ContriSCR = function(E, SCR) {
  # E es la matriz de residuos del modelo
  # SCR es la suma de cuadrados residual
  contribucion = NULL
  for (j in 1:length(SCR)){
    eind<-E[j,]
    signo<-sign(eind)
    contri<-(signo*(eind^2)/SCR[j])*100
    contribucion<-rbind(contribucion,contri)
  }
  rownames(contribucion) = rownames(E)
  return(contribucion)
}

