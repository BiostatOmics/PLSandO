SMC = function(X, coefficients){

  yhat = as.matrix(X) %*% coefficients
  Xhat = tcrossprod(yhat,coefficients)/drop(crossprod(coefficients))
  Xres = X - Xhat

  SST = colSums(Xhat^2)
  SSR = colSums(Xres^2)

  #smc = SST/(SSR/(nrow(X)-2))
  smc = SST/SSR
  return(smc)
}

bagged_pls = function(X, Y, B = 200, ncomp = NULL, scaling, blocks = NULL, scalingY){

  n = nrow(X)
  if (is.null(ncomp)) ncomp = min(n-1, ncol(X))
  preds = array(NA, dim=c(n, ncol(Y), B, ncomp))
  R2 = PRESS = RMSE = Q2 = numeric(ncomp)

  weights = VIP = array(NA, dim=c(ncol(X), ncomp, B))
  coefs = array(NA, dim=c(ncol(X), ncomp, B))

  sMC = array(0, dim=c(ncol(X), ncomp, B))

  # Calculate a PLS model for each of the bagging considered
  for (b in 1:B) {
    idx = sample(1:n, replace = TRUE)
    oob = setdiff(1:n, idx) # Keep track of out of bag samples

    Xb = X[idx, , drop = FALSE]
    Yb = Y[idx, , drop = FALSE]

    if (scaling != 'none') {
      escalado = Scaling(Xb, scaling= scaling, blocks = blocks)
      Xb = escalado$x
      centrado = escalado$centering
      escalado = escalado$scaling
      Xoob = sweep(X[oob, , drop = FALSE], 2, centrado, FUN = "-")
      Xoob = sweep(Xoob, 2, escalado, FUN = "/")
    } else{
      Xoob = X[oob, , drop = FALSE]
    }

    ## Scaling Y

    if (scalingY != 'none') {
      escaladoY = Scaling(Yb, scaling= scalingY, blocks = NULL)
      Yb = escaladoY$x
    }

    mypls = nipals_pls(X = Xb, Y = Yb, ncomp = ncomp)

    weights[,,b] = mypls$weights

    for (j in 1:ncomp){
      weightsStar = mypls$weights[,1:j,drop=FALSE]%*%solve(crossprod(mypls$loadings[,1:j,drop=FALSE], mypls$weights[,1:j,drop=FALSE]))
      coefficients = tcrossprod(weightsStar, mypls$loadingsY[,1:j,drop=FALSE])
      coefs[ , j, b] = coefficients
      preds[oob, , b, j] = as.matrix(Xoob) %*% coefficients

      # sMC calculation
      smcp = SMC(Xb, coefficients)
      fcrit = qf(0.8,1,nrow(Xb)-2)
      sMC[,j,b] = as.vector(ifelse(smcp>fcrit,1,0))

    }
  }

  # Select opt R2

  if (scalingY != 'none') {
    escaladoY = Scaling(Y, scaling= scalingY, blocks = NULL)
    Y = escaladoY$x
  }

  if (scaling != 'none') {
    escalado = Scaling(X, scaling= scaling, blocks = blocks)
    X = escalado$x
  }

  plsr2 = nipals_pls(X = X, Y = Y, ncomp = ncomp)

  for (j in 1:ncomp) {

    Ypred = apply(as.matrix(preds[,,,j]),1, function(y) mean(y,na.rm = T))

    #R2
    yhat = tcrossprod(plsr2$scores[,1:j,drop=FALSE],plsr2$loadingsY[,1:j,drop=FALSE])

    SCR = sum((Y-yhat)^2)
    SCT = sum(Y^2)
    R2[j] = 1- (SCR/SCT)

    #PRESS
    PRESS[j] = sum((Y - Ypred)^2)

    #Q2
    Q2[j] = 1- (PRESS[j]/SCT)

  }

  # Calculate the reweighted PLS model
  # Select opt comp
  r2_diff = diff(R2)
  q2_diff = diff(Q2)

  ncomp = {
    idx = which(!(diff(R2) >= 0.01 & diff(Q2) > 0))
    if (length(idx) == 0) length(R2) else idx[1]}

  #Take into account opt comp + 10
  rcomp = min(min(nrow(X)-1, ncol(X)), ncomp + 10)
  R2 = R2[1:rcomp]
  weights = weights[,1:rcomp,]

  # Calculate the reweighted PLS model
  R2_dif = c(R2[1], diff(R2))

  Stab = numeric(ncol(X))

  for (j in 1:ncol(X)) {
    stability = apply(weights[j,,], 1, function(x) abs(mean(x)) / (sd(x) + 1e-7))
    Stab[j] =  sum(stability * R2_dif)
  }
  #Normalize the weights
  #Stab = (Stab - min(Stab)) / (max(Stab) - min(Stab))
  #coefStab = (coefStab - min(coefStab)) / (max(coefStab) - min(coefStab))

  return(list(Stab = Stab, sMC = sMC, ncomp = rcomp))

}

