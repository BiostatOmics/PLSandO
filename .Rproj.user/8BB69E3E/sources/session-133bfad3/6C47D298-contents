pls_cross = function(X, Y, scaling, blocks, scalingY, ncomp = NULL, k = 5, rep = 10, alpha = 0.05, parallel = T, model, M,thresh){

  if(is.null(ncomp)){
    ncomp = min(nrow(X)-1, ncol(X))
  }

  if(nrow(X)<=5){
    warning("Low number of replicates. Leave-one-out cv will be performed.")
    method = 'loo'
  } else method = 'kfold'

  message("\n Running optimization:")

  options(future.globals.maxSize = 4000*1024^2)
  seed = 1:rep
  if(!isFALSE(parallel)){
    if(is.numeric(parallel)){
      if(.Platform$OS.type == "unix") {
        future::plan("multicore", workers = parallel)
      }else{
        future::plan("multisession", workers = parallel)
      }
    } else{
      nc = future::availableCores() - 1
      if(.Platform$OS.type == "unix") {
        future::plan("multicore", workers = nc)
      }else{
        future::plan("multisession", workers = nc)
      }
      parallel =nc
    }

    crossVal_res = furrr::future_map(1:rep,
                                     ~crossVal(.x, X, Y, ncomp, k, scaling, blocks, scalingY, seed[.x], method, alpha, model, M, thresh),
                                     .progress = TRUE,.options = furrr::furrr_options(seed = TRUE ) )
  } else{
    crossVal_res = purrr::map(1:rep,
                              ~crossVal(.x, X, Y, ncomp, k, scaling, blocks, scalingY, seed[.x], method, alpha, model, M, thresh),
                              .progress = TRUE,.options = furrr::furrr_options(seed = TRUE) )
  }

  future::plan("sequential")

  return(crossVal_res)

}

reweighted_varSel = function(X, Y, B = 200, ncomp = NULL, scaling, blocks = NULL, scalingY){

  bpls = bagged_pls(X, Y, B, ncomp = NULL, scaling, blocks, scalingY)

  thresh = c(0.05, 0.2, 0.3, 0.4, 0.5) #c(0.05,0.2,0.4,0.6,0.8)

  psMC = apply(bpls$sMC, c(1,2), sum)
  psMC = apply(psMC,1,mean)/(dim(bpls$sMC)[3])
  M = diag(as.vector(ifelse(psMC>0,1,0)))

  #CV model for optimun component selection
  res_cross = pls_cross(X = X, Y = Y, scaling = scaling, blocks = NULL, scalingY = scalingY, ncomp = bpls$ncomp, k = 5, rep = 10, parallel = FALSE, model = bpls, M = M, thresh = thresh) #13s de ejecución

  r2_array = simplify2array(lapply(res_cross, function(res) res$R2))
  mean_r2_per_component = apply(r2_array, c(1,2), mean)

  q2_array = simplify2array(lapply(res_cross, function(res) res$Q2))
  mean_q2_per_component = apply(q2_array, c(1,2), mean)

  rmse_array = simplify2array(lapply(res_cross, function(res) res$RMSE))
  mean_rmse_per_component = apply(rmse_array, c(1,2), mean)

  # Improvement of 0.01 in R2 and Q2 positive increment
  r2_diff = diff(mean_r2_per_component)
  q2_diff = diff(mean_q2_per_component)

  best_combo = NULL
  best_score = -Inf

  for (t in 1:5) {
    idx = which((r2_diff[, t] < 0.01) | (q2_diff[, t] <= 0))
    comp = if (length(idx) == 0) nrow(mean_r2_per_component) else idx[1]

    score = 1.5 * mean_q2_per_component[comp, t] + mean_r2_per_component[comp, t] #Emphasize Q2
    score = score - 0.002 * comp # penalize complexity (more components)

    if (score > best_score || (abs(score - best_score) < 1e-4 && t > best_combo["thresh"])) {
      best_combo = c(comp = comp, thresh = thresh[t],t = t)
      best_score = score
    }
  }

  print(best_combo)

  #Scaling of the matrices

  if (scaling != 'none') {
    escalado = Scaling(X, scaling= scaling, blocks = blocks)
    Xesc = escalado$x
  } else{
    Xesc = X
  }

  ## Scaling Y

  if (scalingY != 'none') {
    escaladoY = Scaling(Y, scaling= scalingY, blocks = NULL)
    Yesc = escaladoY$x
  } else{
    Yesc = Y
  }

  plsr_fin = weighted_nipals_pls(X = Xesc, Y = Yesc, model = bpls, ncomp = best_combo['comp'], thresh = best_combo['thresh'], M = M)

  return(list(model = plsr_fin, 'R2'= mean_r2_per_component[best_combo['t']], 'Q2'= mean_q2_per_component[best_combo['t']],'RMSE'= mean_rmse_per_component[best_combo['t']]))

}


