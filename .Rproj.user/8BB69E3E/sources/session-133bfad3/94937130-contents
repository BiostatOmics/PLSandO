# Simulación de datos más faciles y que representen el escenario que queriamos

library(simrel)

set.seed(123)

data = simrel(n = 50, #Number of observations
              p = 300, #Number of predictors
              q = 15, # Number of relevant predictors
              relpos = c(1,2),
              gamma = 0.5, #Decline parameter of eigenvalues
              R2 = 0.8)


simrelplot(data, ncomp = 20)


library(R.matlab)
library(pheatmap)
library(circlize)
library(ComplexHeatmap)

cor_mat = cor(data$X)
cor_to_y = apply(data$X,2,function(x) cor(x, data$Y))

ord <- order(abs(cor_to_y), decreasing = TRUE)
cor_mat <- cor_mat[ord, ord]
cor_to_y <- cor_to_y[ord]

# Define diverging color scale (-1 to 1)
col_fun <- colorRamp2(c(-1, 0, 1), c("blue", "white", "red"))

# Heatmap of variable-variable correlations
ht1 <- Heatmap(cor_mat,
               name = "Correlation",
               col = col_fun,
               cluster_rows = FALSE,
               cluster_columns = FALSE,
               show_row_names = FALSE,
               show_column_names = FALSE)

# Side heatmap: correlation to y
ht2 <- Heatmap(matrix(cor_to_y, ncol=1),
               name = "Corr_to_y",
               col = col_fun,
               cluster_rows = FALSE,
               width = unit(5, "mm"),
               show_row_names = FALSE,
               show_column_names = FALSE)

# Combine plots
ht2 + ht1
