### Geminy superposición   -----------------

MAX_R2 <- 1.0; MIN_R2 <- 0.0
MAX_Q2 <- 1.0; MIN_Q2 <- 0.0
MAX_RMSE <- 100; MIN_RMSE <- 0  # Ejemplo: Si tu RMSE nunca es mayor a 100
MAX_TIME <- 60; MIN_TIME <- 0    # Ejemplo: Si tu tiempo nunca es mayor a 60 segundos

scale_metric <- function(x, min_val, max_val) {
  # Escala Min-Max para forzar el valor entre 0 y 1
  (x - min_val) / (max_val - min_val)
}

# --- 2. Transformar y Escalar df_metrics ---
df_metrics_scaled <- df %>%
  # Aplicar escalamiento a cada métrica
  mutate(
    R2_scaled = scale_metric(R2, MIN_R2, MAX_R2),
    Q2_scaled = scale_metric(Q2, MIN_Q2, MAX_Q2),
    RMSE_scaled = scale_metric(RMSE, MIN_RMSE, MAX_RMSE),
    Tiempo_scaled = scale_metric(time, MIN_TIME, MAX_TIME)
  ) %>%
  # Pivotear a formato largo
  pivot_longer(
    cols = c(R2_scaled, Q2_scaled, RMSE_scaled, Tiempo_scaled),
    names_to = "Metric_Scaled",
    values_to = "Percent_Scaled"
  ) %>%
  # Mapeo Forzado: Asignar cada métrica escalada al 'Group' de faceta
  mutate(
    Group = case_when(
      Metric_Scaled == "R2_scaled" ~ "Irr",
      Metric_Scaled == "Q2_scaled" ~ "Noisy",
      Metric_Scaled == "RMSE_scaled" ~ "RnSel",
      Metric_Scaled == "Tiempo_scaled" ~ "Sel",
      TRUE ~ NA_character_
    ),
    # Obtener el valor original para etiquetas del eje secundario
    Metric_Original = case_when(
      Metric_Scaled == "R2_scaled" ~ R2,
      Metric_Scaled == "Q2_scaled" ~ Q2,
      Metric_Scaled == "RMSE_scaled" ~ RMSE,
      Metric_Scaled == "Tiempo_scaled" ~ time,
      TRUE ~ NA_real_
    ),
    # Crear una variable única para el eje X de las métricas (por ejemplo, el centro del panel)
    X_Axis_Pos = 'DS2-High' # O cualquier valor de 'Dataset' para centrar la línea/punto
  ) %>%
  # Seleccionar solo las columnas necesarias para el plot
  select(Dataset, Model, Group, Percent_Scaled, Metric_Original, Metric_Scaled)

# --- 3. Combinar los Dataframes (Opcional, si quieres todos los datos juntos) ---
