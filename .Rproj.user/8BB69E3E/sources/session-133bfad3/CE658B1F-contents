groups  <- c("RnSel", "Irr", "Sel", "noisy")
datasets <- 1:6
models <- c("Base","Model1","Model4","Model6","Model7")

rows <- list()
r <- 1

for (ds in datasets) {
  for (g in groups) {

    # Build the variable name, e.g. "RnSel1", "Irr4", etc.
    varname <- paste0(g, ds)

    # Get the numeric vector
    vals <- get(varname)

    if (length(vals) != length(models)) {
      stop("Length mismatch in ", varname)
    }

    for (m in seq_along(models)) {
      rows[[r]] <- list(
        Dataset = paste0("DS", ds),
        Group   = g,
        Model   = models[m],
        Percent = vals[m]
      )
      r <- r + 1
    }
  }
}

df <- do.call(rbind, lapply(rows, as.data.frame, stringsAsFactors = FALSE))

