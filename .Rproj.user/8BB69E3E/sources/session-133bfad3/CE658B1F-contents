reverse_scale_irr <- function(p) { p * (MAX_R2 - MIN_R2) + MIN_R2 }
reverse_scale_noisy <- function(p) { p * (MAX_Q2 - MIN_Q2) + MIN_Q2 }
reverse_scale_rnsel <- function(p) { p * (MAX_RMSE - MIN_RMSE) + MIN_RMSE }
reverse_scale_sel <- function(p) { p * (MAX_TIME - MIN_TIME) + MIN_TIME }

# Función de etiquetas para el segundo eje Y
# Esta función es compleja porque la transformación es diferente en cada faceta (Group)
sec_y_labels <- function(y_scaled) {
  # Esta es una simplificación; idealmente usarías el argumento 'facet' del plot
  # o una librería externa como 'ggh4x' para manejar ejes por faceta.
  # Para un eje secundario general, solo puedes usar una transformación, lo cual es el mayor
  # problema de este enfoque.

  # Por ahora, solo usaremos una escala de R2/Q2, ya que suelen ser la métrica principal
  # y dejar que el usuario sepa que los valores de RMSE/Tiempo son solo indicadores.
  sapply(y_scaled, function(p) round(p * (MAX_R2 - MIN_R2) + MIN_R2, 2))
}

# --- EL PLOT ---
ggplot(df, aes(x = Dataset, y = Percent, fill = Model)) +
  # 1. Barras (Datos originales)
  geom_col(position = position_dodge(width = 0.8), width = 0.7) +

  # 2. Puntos/Líneas (Nuevas métricas, usando df_metrics_scaled)
  # Usamos una posición fija en X (X_Axis_Pos) para superponer las métricas como un resumen
  geom_point(
    data = df_metrics_scaled,
    aes(y = Percent_Scaled, color = Model, group = Model),
    size = 4,
    position = position_dodge(width = 0.8) # Mantener la alineación con las barras
  ) +
  geom_line(
    data = df_metrics_scaled,
    aes(y = Percent_Scaled, color = Model, group = Model),
    linewidth = 1,
    position = position_dodge(width = 0.8)
  ) +

  # 3. Escalas y Facetas
  scale_fill_manual(
    name = "Model",
    values = c("Base" = "#44344f", "Model1" = "#564d80", "Model2" = "#98a6d4",
               "Model4" = "#9fc490", "Model5" = "#dff2d8", "Model6" = "#cccccc",
               "Model7" = "#126D6D")
  ) +
  scale_color_manual(
    name = "Model",
    values = c("Base" = "#44344f", "Model1" = "#564d80", "Model2" = "#98a6d4",
               "Model4" = "#9fc490", "Model5" = "#dff2d8", "Model6" = "#cccccc",
               "Model7" = "#126D6D") # Usa colores distintos para diferenciar
  ) +

  # Mapear los nombres de las facetas para que muestren la métrica
  facet_grid(. ~ Group, scales = "free_x", switch = "x", labeller = labeller(
    Group = c(
      "Irr" = "Irr \n(R2)",
      "Noisy" = "Noisy \n(Q2)",
      "RnSel" = "RnSel \n(RMSE)",
      "Sel" = "Sel \n(Tiempo)"
    )
  )) +

  # 4. Eje Y Secundario (El truco)
  scale_y_continuous(
    name = "% Selected Variables", # Eje Y Primario (Barras)
    sec.axis = sec_axis(
      trans = ~ . , # Usar la misma transformación de datos escalados
      labels = function(y_scaled) {
        # ADVERTENCIA: Esta es una simplificación de etiquetas.
        # Solo podemos mostrar etiquetas de una sola escala a menos que usemos ggh4x.
        # Aquí, mostraré solo la escala R2/Q2.
        sapply(y_scaled, function(p) round(reverse_scale_irr(p), 2))
      },
      name = "Métricas escaladas a 0-1"
    )
  ) +

  # 5. Temas y Etiquetas
  labs(
    x = "",
    title = "Comparación: % Variables Seleccionadas (Barras) vs. Métricas de Rendimiento (Líneas)"
  ) +
  theme_minimal(base_size = 14) +
  theme(
    axis.text.x = element_text(angle = 60, hjust = 1),
    panel.grid.major.x = element_blank(),
    strip.placement = "outside",
    strip.background = element_rect(fill = "grey90", color = NA),
    legend.position = "bottom"
  )

