setwd('.')
suppressMessages(source("auxFunctions.R"))
suppressMessages(source("MORE_GLM.R"))
suppressMessages(source("more.R"))
library(stringr)

cmd<-commandArgs(trailingOnly = TRUE)

#First argument is the seed
set.seed(as.numeric(cmd[1]))

#Second the multicollinearity method to be applied
col.filter = cmd[2]

#Third the correlation threshold
corre = cmd[3]

#Fourth the number of replicates

#Third the directory where the data is stored

mydata <- readRDS(file = paste('~/MORE/data/data30/my_simulated_bulkMOSim_30',cmd[5], cmd[1],cmd[4],'rep.rds', sep = '_'))
all_settings <- readRDS(file = paste('~/MORE/data/data30/my_settings_30',cmd[5],cmd[1],cmd[4],'rep.rds', sep = '_'))
edesign<- readRDS(file = paste('~/MORE/data/data30/edesign_30',cmd[5],cmd[1],cmd[4],'rep.rds', sep = '_'))

suppressMessages(library(limma))
suppressMessages(library(edgeR))
suppressMessages(library(NOISeq))

cond = edesign[,1]
myfactors<-data.frame("Group"=cond)

condi<-c(rep('cond1',as.numeric(cmd[4])),rep('cond2',as.numeric(cmd[4])))
design<-model.matrix(~0+condi)
colnames(design)<-c('cond1','cond2')
rownames(design)<-rownames(edesign)

cont.matrix<-makeContrasts(contrasts='cond1-cond2',levels=c('cond1','cond2'))

filtered <- filtered.data(mydata[['RNA-seq']], factor = myfactors, norm = FALSE, method = 1, cpm = 1)
y <- DGEList(counts = filtered, group = cond)
y <- calcNormFactors(y, method = "TMM")
v <- voom(y, design = model.matrix(~0 + cond))
vfit <- lmFit(object = v, design = design)
fit.cont <- contrasts.fit(fit = vfit, contrasts = cont.matrix)
efit <- eBayes(fit.cont)
results <- topTable(efit, adjust.method = "fdr", sort.by = "P", n = Inf)
mydata[['RNA-seq']] <- v$E[rownames(results[which(results[,'adj.P.Val'] < 0.05),]),]

GeneExpressionDE<-mydata[[1]]

data.omics<-mydata[-1]

#Now we convert ChIP-seq into 0/1

discretize_countsCOLROW <- function(df) {
  ## Transform into relative percentages per sample (sum of column is 1)
  df <- df/colSums(df)
  ## And now per gene
  df <- df/rowSums(df)
  # Threshold is the relative abundance if the genes are the same in the samples
  threshold <- 1/length(colnames(df))
  # If below the threshold, 0, if above 1
  for (i in 1:ncol(df)) {
    df[,i] <- ifelse(df[,i] < threshold, 0, 1)
  }
  return(df)
}
data.omics$`ChIP-seq`<-discretize_countsCOLROW(data.omics$`ChIP-seq`)
problema_raro = c(grep("e\\+", rownames(data.omics$`Methyl-seq`), value = TRUE))
data.omics$`Methyl-seq` = data.omics$`Methyl-seq`[-which(rownames(data.omics$`Methyl-seq`) %in% problema_raro),] 

#Filter from all_settings regulators that have been removed due to not being DE

all_settings<-all_settings[-1]
all_settings<-lapply(names(all_settings), function(x) all_settings[[x]][all_settings[[x]]$ID %in% rownames(data.omics[[x]]),])
names(all_settings)<-names(data.omics)

#Erase duplicates from Methylation
all_settings$`Methyl-seq`<-unique(all_settings$`Methyl-seq`)

associations = lapply(all_settings, function(x) x[,c(2,1)])
associations = lapply(associations, function(x) x[!is.na(x$Gene),])
associations = lapply(associations, as.data.frame)
edesign = edesign[,-c(3,4)]

#determine some parameters for MORE
min.var = c(0,0.045,0.045,0,0.045)
names(min.var) = names(data.omics)


GLMresults = more(GeneExpression = GeneExpressionDE,  # lo ejecutamos para los 20 primeros genes
                    associations=associations,
                    data.omics=data.omics,
                    edesign=edesign[,-2 , drop=FALSE],
                    center = TRUE, scale = TRUE,
                    interactions.reg = TRUE,
                    min.variation=min.var, elasticnet.glm = NULL,
                    correlation.glm = corre, col.filter.glm = col.filter, method = 'glm', scaletype = cmd[6],
                    all_settings = all_settings)

saveRDS(GLMresults, paste("~/MORE/MOREgit/results_alpha/GLMresults_30",cmd[5],cmd[6], cmd[1], cmd[2], cmd[3],cmd[4], "rep.rds", sep = '_'))
