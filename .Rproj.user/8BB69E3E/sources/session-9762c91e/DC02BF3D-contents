hubgene_table<-function(output, regpcond){
  
  ngroups = length(table(output$arguments$groups))
  nhgenes = length(output$GlobalSummary$HubGenes)
  
  #Create results table
  Table = matrix(0,nrow=nhgenes ,ncol = ngroups+1)
  
  #1 column all possible regulations of the hub genes
  
  Table[,1]<-sapply(output$GlobalSummary$HubGenes, function(x){
    #Identify the omic they belong to
    sum(sapply(names(output$arguments$omic.type), function(y){
      length(which(output$arguments$associations[[y]][,1]==x))
    }))
  })
  
  #Rest of the columns significant regulations for each group
  Tab<-sapply(output$GlobalSummary$HubGenes, function(x,Table){
    
    regpconhg=regpcond[regpcond$gene==x,]
    j = grep(x,output$GlobalSummary$HubGenes)
    Table[j,-1]<-sapply(1:ngroups, function(y,regpconhg){
      i=grep('Group',colnames(regpconhg))[y]
      
      return(nrow(regpconhg[regpconhg[,i]!=0,]))
    },regpconhg)
  }, Table)
  
  Table[,-1]<-t(Tab)
  Table<-cbind(Table,round(Table[,-1]/Table[,1]*100,2))
  rownames(Table)=output$GlobalSummary$HubGenes
  colnames(Table)=c('Initial',sub('Group_', '',colnames(regpcond)[grep('Group',colnames(regpcond))]),paste0('%',sub('Group_', '',colnames(regpcond)[grep('Group',colnames(regpcond))])))
  
  return(Table)
  
}

