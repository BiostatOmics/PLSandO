omic_table<-function(output, regpcond){
  
  ngroups = length(table(output$arguments$groups))
  nomics = length(output$arguments$omic.type)
  
  #Create results table
  Table <- matrix(0,nrow=nomics ,ncol = ngroups+1)
  
  #1 column all possible regulations
  
  Table[,1]<-sapply(output$arguments$associations, nrow)
  
  #Rest of the columns with the significant for each group
  
  Tab<-sapply(names(output$arguments$omic.type), function(x,Table){
    
    regomcond<-regpcond[regpcond$omic==x,]
    j = grep(x,names(output$arguments$omic.type))
    Table[j,-1]<-sapply(1:ngroups, function(y,regomcond){
      i=grep('Group',colnames(regomcond))[y]
      
      return(nrow(regomcond[regomcond[,i]!=0,]))
    },regomcond)
  }, Table)
  
  Table[,-1]<-t(Tab)
  Table<-cbind(Table,round(Table[,-1]/Table[,1]*100,2))
  rownames(Table)=names(output$arguments$omic.type)
  colnames(Table)=c('Initial',sub('Group_', '',colnames(regpcond)[grep('Group',colnames(regpcond))]),paste0('%',sub('Group_', '',colnames(regpcond)[grep('Group',colnames(regpcond))])))
  return(Table)
}


gloreg_table<-function(output, regpcond){
  
  ngroups = length(table(output$arguments$groups))
  ngreg = length(output$GlobalSummary$GlobalRegulators)
  
  #Create results table
  Table = matrix(0,nrow=ngreg ,ncol = ngroups+1)
  
  #1 column all possible regulations of the gobal regulators
  
  Table[,1]<-sapply(output$GlobalSummary$GlobalRegulators, function(x,regpcond,output){
    #Identify the omic they belong to
    om = regpcond[x,'omic']
    return(length(which(output$arguments$associations[[om]][,2]==x)))
  },regpcond, output)
  
  #Rest of the columns significant regulations for each group
  Tab<-sapply(output$GlobalSummary$GlobalRegulators, function(x,Table){
    
    regpconreg=regpcond[regpcond$regulator==x,]
    j = grep(x,output$GlobalSummary$GlobalRegulators)
    Table[j,-1]<-sapply(1:ngroups, function(y,regpconreg){
      i=grep('Group',colnames(regpconreg))[y]
      
      return(nrow(regpconreg[regpconreg[,i]!=0,]))
    },regpconreg)
  }, Table)
  
  Table[,-1]<-t(Tab)
