plotmore<-function(output, gene, reg, axe1 = 1, axe2 = 2 ){
  
  
  #Create the PCA model only with the data of the DEG
  mypca = ropls::opls(t(output$arguments$GeneExpression), info.txtC = 'none', fig.pdfC='none')
  
  #Identify the omic of the regulator
  om = output$ResultsPerGene[[gene]]$allRegulators[reg, 'omic']
  
  #Create the score plot colored by the gene
  df <- data.frame(x = mypca@scoreMN[,axe1], 
                   y = mypca@scoreMN[,axe2],
                   color1 = as.numeric(output$arguments$GeneExpression[gene,]),
                   color2 = as.numeric(output$arguments$dataOmics[[om]][reg,]),
                   color3 = as.vector(output$arguments$edesign))
  
  
  # Create the plot
  p1<-ggplot(df, aes(x = x, y = y, color = color1)) +
    geom_point(shape = 18, size = 3) +
    scale_color_gradient(low = "blue", high = "red") +
    labs(title = paste("PCA colored by",gene), x = paste('t', axe1), y = paste('t', axe2)) +
    theme_minimal()+
    guides(color = guide_colorbar(title = ''))
  
  # Create the plot
  p2<-ggplot(df, aes(x = x, y = y, color = color2)) +
    geom_point(shape = 18, size = 3) +
    scale_color_gradient(low = "blue", high = "red") +
    labs(title = paste("PCA colored by",reg), x = paste('t', axe1), y = paste('t', axe2)) +
    theme_minimal()+
    guides(color = guide_colorbar(title = ''))
  
  
  # Create the plot
  p3<-ggplot(df, aes(x = x, y = y, color = df[,5])) +
    geom_point(shape = 18, size = 3) +
    labs(title = "PCA colored by condition", x = paste('t', axe1), y = paste('t', axe2)) +
    theme_minimal()+
    scale_color_manual(values = rainbow(length(unique(df[,5]))), name = "Condition")
  
  gridExtra::grid.arrange(p1, p2,p3, nrow = 1)
  

}


