nipals_mbpca = function(X, ncomp = NULL ){
  
  b_names = names(X)
  
  block_weight = matrix(0,nrow = length(X),ncol =ncomp )
  super_scores = matrix(0, nrow = nrow(X[[1]]), ncol = ncomp )
  super_loadings = matrix(0, nrow = length(X), ncol = ncomp )
  eigen = rep(0, ncomp)
  
  tr = setNames(lapply(b_names, function(x) sum(diag(t(X[[x]])%*%X[[x]]))),b_names)
  
  for (i in 1:ncomp){
    
    iter = 1
    w_old = rep(0, length(X))
    
    #Choose an arbitrary starting global score
    rand = X[[sample(length(X), 1)]]
    super_t_old = rand[, sample(ncol(rand), 1), drop=FALSE]
    
    block_p = setNames(lapply(b_names, function(x) (t(X[[x]])%*%super_t_old) / drop(t(super_t_old)%*%super_t_old)), b_names)
    block_p = setNames(lapply(b_names, function(x) block_p[[x]] / sqrt(drop(crossprod(block_p[[x]])))), b_names)
    block_t = setNames(lapply(b_names, function(x) (X[[x]] %*% block_p[[x]])/sqrt(ncol(X[[x]]))), b_names)
    
    T_scores = do.call(cbind, block_t)
    w_new = (t(T_scores) %*% super_t_old) / drop(t(super_t_old)%*%super_t_old)
    w_new = w_new / sqrt(drop(crossprod(w_new)))
    
    super_t_new = T_scores %*% w_new
    
    while(sqrt(drop(crossprod(w_new-w_old)))>1e-6 && iter<100){
      
      #Update
      super_t_old = super_t_new
      w_old = w_new
      iter = iter + 1
      
      #Recalculate block_scores, loadings, super_scores and loadings
      block_p = setNames(lapply(b_names, function(x) (t(X[[x]])%*%super_t_old) / drop(t(super_t_old)%*%super_t_old)), b_names)
      block_p = setNames(lapply(b_names, function(x) block_p[[x]] / sqrt(drop(crossprod(block_p[[x]])))), b_names)
      block_t = setNames(lapply(b_names, function(x) (X[[x]] %*% block_p[[x]])/sqrt(ncol(X[[x]]))), b_names)
      
      T_scores = do.call(cbind, block_t)
      w_new = (t(T_scores) %*% super_t_old) / drop(t(super_t_old)%*%super_t_old)
      w_new = w_new / sqrt(drop(crossprod(w_new)))
      
      super_t_new = T_scores %*% w_new
    }
    
    if (i==1){
      block_scores = block_t
      block_loadings = block_p
    } else{
      block_scores = setNames(lapply(b_names, function(x) cbind(block_scores[[x]], block_t[[x]])),b_names)
      block_loadings = setNames(lapply(b_names, function(x) cbind(block_loadings[[x]], block_p[[x]])),b_names)
    }
    
    super_scores[,i] = super_t_new
    super_loadings[,i] = w_new
    eigen[i] = t(super_t_new)%*%super_t_new / (nrow(X[[1]])-1)
    
    X = setNames(lapply(b_names, function(x) X[[x]]- block_t[[x]] %*% t(block_p[[x]]) ),b_names)
    
    Eb = setNames(lapply(b_names, function(x) sum(diag(t(X[[x]])%*%X[[x]]))),b_names)
    explvarB = if(i==1)  setNames(lapply(b_names, function(x) (1-Eb[[x]]/tr[[x]])*100) ,b_names) else setNames(lapply(b_names, function(x) cbind(explvarB[[x]],(1-Eb[[x]]/tr[[x]])*100)) ,b_names)
    
  }
  
  #Change the colnames and save the rownames
  block_scores = lapply(block_scores, function(x) {
    colnames(x) = paste0("p", 1:ncomp)
    rownames(x) = rownames(X[[1]])
    return(x)
  })
  
  block_loadings = lapply(names(block_loadings), function(x) {
    colnames(block_loadings[[x]]) = paste0("p", 1:ncomp)
    rownames(block_loadings[[x]]) = colnames(X[[x]])
    return(block_loadings[[x]])
  })
  names(block_loadings) = b_names
  
  colnames(super_loadings) = colnames(super_scores) = paste0("p", 1:ncomp)
  rownames(super_loadings) = b_names
  rownames(super_scores) = rownames(X[[1]])
  
  return(list(block_scores=block_scores, block_loadings = block_loadings, super_scores = super_scores,super_loadings= super_loadings, eigen = eigen, explvarB = explvarB))
}

Preparing = function(x, includeFactors = TRUE, CVfilter = 0.01, excludeNA = 0.2) {
  
  x = as.data.frame(x)
  
  # Comprobar que los rownames no sean numéricos y sustituirlos en tal caso para que no den problemas
  
  if(all(!is.na(suppressWarnings(as.numeric(rownames(x)))))) {
    rownames(x) = paste0('r', rownames(x))
    warning('To avoid problems with numeric identifiers, we added r prefix to the identifiers')
  }
  
  # Guardar todo el proceso en una especie de summary para que lo puedan consultar en cualquier momento
  
  removed_vars = data.frame('Variable' = colnames(x), 'Model' = rep('', ncol(x)), 'Problem' = rep('', ncol(x)))
  
  # Calcular el % faltantes for observación y variable --> Eliminar los que exceden cutoff --> mensaje informativo
  
  X = remove_NA(x, excludeNA = excludeNA, removed_vars= removed_vars)
  removed_obs = X$removed_obs
  
  # Detectar factores y variables tipo texto y si TRUE, convertir, si FALSE excluir --> mensaje informativo
  # Convertir a numeric las variables que lo sean y tratar como factors el resto
  X = prepare_x(X$x, includeFactors = includeFactors, removed_vars = X$removed_vars)
  
  # Filtrar variables con baja variabilidad --> mensaje informativo
  X = remove_CV(X$x, CVfilter = CVfilter, removed_vars= X$removed_vars)
  
  # Las que no hayan sido excluidas las identifico como incluidas?
  
  return(list(x = X$x, removed = list('Variables'=X$removed_vars, 'Observations' = removed_obs)))
}





### PCA model

# x: matrix or data.frame or list (if multi-block)


pca = function(x,
               ncomp = NULL,
               algo = c("nipals", "svd", "mbpca")[1],
               scaling = c("none", "center", "standard", "softBlock", "hardBlock")[3])
{
  
  if(algo == 'mbpca'){
    
    if (class(x)!='list') return(stop('To perform multiblock PCA, please provide the block information as a list where each element corresponds to one block'))
    if (length(unique(sapply(x, nrow)))!=1) return(stop('All blocks must have the same observations'))
    
    b_names = names(x)
    
    P = lapply(x, function(y){
      if(!all(sapply(y, is.numeric))) {
        warning('Categorical variables automatically converted to dummy variables and default filters for NAs and CV applied.\n If the user does not want to use any default filtering, consider using Preparing function before executing pca to convert categorical variables into dummies.')
        Preparing(y, includeFactors = T, CVfilter = 0.01, excludeNA = 0.2)
      } else {
        Preparing(y, CVfilter = 0.00001, excludeNA = 1) #Evitar nearZeroVariance variables pero no aplicar ningún filtro extra
      }
    })
    
    x = setNames(lapply(b_names, function(y) P[[y]]$x), b_names)
    X = x
    
    if(is.null(ncomp)) ncomp = min(sapply(X, function(x) min(nrow(x)-1, ncol(x))))
    
    if (scaling != 'none') {
      blocks = NULL
      escalado = setNames(lapply(b_names, function(y){
        if(scaling%in%c('softBlock', 'hardBlock')) blocks = rep(1, ncol(x[[y]]))
        return(Scaling(x[[y]], scaling = scaling, blocks = blocks))
      } ),b_names)
      
      x = setNames(lapply(b_names, function(y) escalado[[y]]$x), b_names)
      centrado = setNames(lapply(b_names, function(y) escalado[[y]]$centering), b_names)
      escalado = setNames(lapply(b_names, function(y) escalado[[y]]$scaling), b_names)
    } else{
      escalado = setNames(lapply(x,function(y) rep(1, times = ncol(y))),b_names)
      centrado = setNames(lapply(x,function(y) rep(0, times = ncol(y))),b_names)
    }
    
    scal_param = setNames(lapply(b_names, function(y){
      center = centrado[[y]]
      scale = escalado[[y]]
      return(data.frame("center" = center , "scale" = scale))
    }),b_names)
    
    #Habría que discutir si metemos el caso de valores faltantes a MBPCA
    mypca = nipals_mbpca(x, ncomp = ncomp)
    
    explVar = data.frame("comp" = factor(1:ncomp),
                         "eigenVal" = mypca$eigen,
                         "percVar" = round(100*mypca$eigen/sum(mypca$eigen),4),
                         "cumPercVar" = round(100*cumsum(mypca$eigen/sum(mypca$eigen)),4))
    explVarBlock = setNames(lapply(b_names, function(y){
      expl = data.frame("comp" = factor(1:ncomp),
                        "percVar" = round(c(mypca$explvarB[[y]][1] ,diff(as.numeric(mypca$explvarB[[y]]))),4),
                        "cumPercVar" = t(round(mypca$explvarB[[y]],4)))
    }),b_names)
    
    desSummary = setNames(lapply(b_names, function(y){
      des = data.frame(c("Samples","Variables","Excluded Near-Zero Variables","Missing Values"),
                       c(nrow(x[[y]]),ncol(x[[y]]),length(which(P[[y]]$removed$Variables$Problem == 'Low CV')),
                         paste0(length(which(is.na(x[[y]]))), " (",round((length(which(is.na(x[[y]]))) / (nrow(x[[y]]) * ncol(x[[y]]))) * 100, 2), "%)")), stringsAsFactors = FALSE)
      colnames(des) = NULL
      return(des)
    }),b_names)
    
    return(list("block_scores" = mypca$block_scores,
                "block_loadings" = mypca$block_loadings,
                "global_scores" = mypca$super_scores,
                "global_loadings" = mypca$super_loadings,
                "X" = x, ### con escalado y sin variables con baja variabilidad
                "scaling" = scal_param,
                "explVar" = explVar,
                "explVarBlock" = explVarBlock,
                "summary" = desSummary, ## completar si se desea dar + info de lo que se ha hecho
                "ncomp" = ncomp,
                "input" = list("scalingType" = scaling, "X" = X, 'algo' = algo)))
    
    
  } else{
    if(!all(sapply(x, is.numeric))) {
      warning('Categorical variables automatically converted to dummy variables and default filters for NAs and CV applied.\n If the user does not want to use any default filtering, consider using Preparing function before executing pca to convert categorical variables into dummies.')
      P = Preparing(x, includeFactors = T, CVfilter = 0.01, excludeNA = 0.2)
      x = P$x
    } else {
      P = Preparing(x, CVfilter = 0.00001, excludeNA = 1) #Evitar nearZeroVariance variables pero no aplicar ningún filtro extra
      x = P$x
    }
    
    X = x
    
    if (is.null(ncomp)) ncomp = min(ncol(x), nrow(x)-1)
    
    if(class(x)!='list' && scaling %in% c('softBlock','hardBlock')) blocks = rep(1, times = ncol(x)) else blocks = NULL
    
    if (class(x)=='list') {
      if (!scaling %in% c("softBlock", "hardBlock")) warning('When blocks are considered we recommend using either softBlock or hardBlock scaling')
      if (length(unique(sapply(x, nrow)))!=1) return(stop('All blocks must have the same observations'))
      blocks = rep(seq_along(x), times = sapply(x, nrow) )
      x = do.call(cbind, x)
    }
    
    if (scaling != 'none') {
      escalado = Scaling(x, scaling= scaling, blocks = blocks)
      x = escalado$x
      centrado = escalado$centering
      escalado = escalado$scaling
    } else{
      escalado = rep(1, times = ncol(x))
      centrado = rep(0, times = ncol(x))
    }
    
    if(any(is.na(x)) && algo == 'svd') return(stop('Missing values detected. Please remove or impute them, or use the nipals algorithm instead'))
    
    mypca = if(algo == 'svd') svd_pca(x, ncomp = ncomp) else nipals_pca(x, ncomp = ncomp)
    
    explVar = data.frame("comp" = factor(1:length(mypca$eigen)),
                         "eigenVal" = mypca$eigen,
                         "percVar" = round(100*mypca$eigen/sum(mypca$eigen),4),
                         "cumPercVar" = round(100*cumsum(mypca$eigen/sum(mypca$eigen)),4))
    
    desSummary = data.frame(c("Samples","Variables","Excluded Near-Zero Variables","Missing Values"),
                            c(nrow(x),ncol(x),length(which(P$removed$Variables$Problem == 'Low CV')),
                              paste0(length(which(is.na(x))), " (",round((length(which(is.na(x))) / (nrow(x) * ncol(x))) * 100, 2), "%)")), stringsAsFactors = FALSE)
    colnames(desSummary) <- NULL
    
    return(list("scores" = mypca$scores,
                "loadings" = mypca$loadings,
                "X" = x, ### con escalado y sin variables con baja variabilidad
                "scaling" = data.frame("center" = centrado , "scale" = escalado),
                "explVar" = explVar,
                "summary" = desSummary, ## completar si se desea dar + info de lo que se ha hecho
                "ncomp" = ncomp,
                "input" = list("scalingType" = scaling, "X" = X, 'algo' = algo)))
  }
  
}


