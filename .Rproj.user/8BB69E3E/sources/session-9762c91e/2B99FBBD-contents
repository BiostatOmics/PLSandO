#Crear una función para el computo del f1score en los resultados de MORE

Createf1table = function(signifreg, all_settings, gene){
  resmat = matrix(0, nrow = 2,ncol=2)
  all_settings = lapply(all_settings, as.data.frame)
  #take only the regulators of the gene
  all_set_gene = lapply(all_settings, function(x) x[which(x[,2]==gene),])
  #search significant regulators
  signireg = array(unlist(sapply(all_set_gene, function(x) x[rowSums(is.na(cbind(x[,3],x[,4]))) != 2,1])))
  #search significant regulators
  nosignireg = array(unlist(sapply(all_set_gene, function(x) x[!rowSums(is.na(cbind(x[,3],x[,4]))) != 2,1])))
  #Compute TP
  resmat[1,1] = length(intersect(signifreg, signireg))
  #Compute FP
  resmat[1,2] = length(setdiff(signifreg,signireg))
  #Compute FN
  resmat[2,1] = length(setdiff(signireg,signifreg))
  #Compute TN
  resmat[2,2] = length(setdiff(nosignireg,signifreg))
  return(resmat)
}

ctables = function(signifreg, signireg, nosignireg){
  resmat = matrix(0, nrow = 2,ncol=2)
  #Compute TP
  resmat[1,1] = length(intersect(signifreg, signireg))
  #Compute FP
  resmat[1,2] = length(setdiff(signifreg,signireg))
  #Compute FN
  resmat[2,1] = length(setdiff(signireg,signifreg))
  #Compute TN
  resmat[2,2] = length(setdiff(nosignireg,signifreg))
  return(resmat)
}

Createf1tableperomic = function(signifreg, all_settings, gene){
  resmat = matrix(0, nrow = 2,ncol=2)
  all_settings = lapply(all_settings, as.data.frame)
  signifreg = lapply(all_settings, function(x) intersect(x[,'ID'],signifreg))
  #take only the regulators of the gene
  all_set_gene = lapply(all_settings, function(x) x[which(x[,'Gene']==gene),])
  #search significant regulators
  signireg = lapply(all_set_gene, function(x) x[rowSums(is.na(cbind(x[,'Effect.Group1'],x[,'Effect.Group2']))) != 2,1])
  names(signireg) = names(all_set_gene)
  #search significant regulators
  nosignireg = lapply(all_set_gene, function(x) x[!rowSums(is.na(cbind(x[,'Effect.Group1'],x[,'Effect.Group2']))) != 2,1])
  names(nosignireg) = names(all_set_gene)
  oresmat = vector("list", length = length(signireg))
  names(oresmat) = names(signireg)
  for (i in 1:length(signireg)){
    oresmat[[i]] = ctables(signifreg = signifreg[[i]], signireg = signireg[[i]], nosignireg = nosignireg[[i]])
  }
  return(oresmat)
}
Sumtableperomic = function(tTABLE, nTABLE){
  tTABLE = lapply(names(tTABLE), function(x) tTABLE[[x]]+nTABLE[[x]])
  names(tTABLE) = names(nTABLE)
  return(tTABLE)
}
f1s = function(t, epsilon){
  #takes as argumenta a table in which t[1,1]=TP, t[1,2] = FP, t[2,1]= FN, t[2,2] = TN
  precision = t[1,1] / (t[1,1]+t[1,2]+epsilon) #correct P predictions relative to total P predictions
  recall = t[1,1] / (t[1,1]+t[2,1]+epsilon) # correct P predictions relative to total actual positives
  return((2*precision*recall)/(precision+recall+epsilon))
}

accuracy = function(t, epsilon){
  recall = t[1,1] / (t[1,1]+t[2,1]+epsilon)
  specificity = t[2,2] / (t[2,2]+t[1,2]+epsilon)
  return((recall*specificity)/2)
}


f1res <- function(output, all_settings,filename){

  mt = matrix(0,2,2)
  Tt = rep(list(mt), length(output$arguments$regulatoryData))
  names(Tt) = names(output$arguments$regulatoryData)

  for (i in 1:length(output$ResultsPerGene)){
    gene = names(output$ResultsPerGene)[i]
    to = Createf1tableperomic(output$ResultsPerGene[[gene]]$significantRegulators, all_settings, gene)
    Tt = Sumtableperomic(Tt, to)
  }

  if(!is.null(output$GlobalSummary$GenesNOmodel)){
    for (i in 1:nrow(output$GlobalSummary$GenesNOmodel)){
      gene = output$GlobalSummary$GenesNOmodel[i,1]
      to = Createf1tableperomic(c(NaN), all_settings, gene)
      Tt = Sumtableperomic(Tt, to)
    }
  }
  epsilon = 0.00001
  f1scoro = sapply(Tt, function(x) f1s(x,epsilon = epsilon))
  accuo = sapply(Tt, function(x) accuracy(x,epsilon = epsilon))
  TotalTable = Reduce('+',Tt)
  f1scor = f1s(TotalTable, epsilon = epsilon)
  accu = accuracy(TotalTable,epsilon = epsilon)

  resu = list(f1score=f1scor, accuracy=accu, f1scoreo=f1scoro,accuracyo=accuo, ctime = output$results$ctime)

  output$results = resu

  saveRDS(output, paste0("E:/MORE_i2sysbio/Stepw/results/tablas/",filename))

}



