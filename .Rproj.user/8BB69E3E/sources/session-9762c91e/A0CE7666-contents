mbpca = function(X, ncomp = NULL){

  #Calcular el PCA de cada uno de los bloques primero

  block_scores = list()
  block_loadings = list()

  if(is.null(ncomp)) ncomp = sapply(X, function(x) min(nrow(x)-1, ncol(x)))

  for (b in 1:length(X)){
    temp = nipals_pca(X[[b]], ncomp = ncomp[b])
    block_scores[[b]] = temp$scores
    block_loadings[[b]] = temp$loadings
  }
  names(block_loadings) = names(block_scores) = names(ncomp)

  T_scores = do.call(cbind, block_scores)

  temp = nipals_pca(T_scores)
  super_scores = temp$scores
  super_loadings = temp$loadings
  block_weight =  t(T_scores) %*% super_scores
  block_weight = t(t(block_weight) / sqrt(colSums(block_weight^2)))

  return(list(block_scores = block_scores, block_loadings = block_loadings, block_weight = block_weight, super_scores= super_scores, super_loadings = super_loadings))

}

#The starting score is taken from each block and a global score is suppossed to be taken

nipals_mbpca_incorrect = function(X, ncomp = NULL ){

  b_names = names(X)

  if(is.null(ncomp)) ncomp = min(sapply(X, function(x) min(nrow(x)-1, ncol(x))))

  nipals_comp = function(X){

    if(any(is.na(X))){
      missNA = T
      X_sinNA = X
      X_sinNA[is.na(X)]= 0
      C = matrix(1, ncol = ncol(X), nrow = nrow(X) )
      C[is.na(X)] = 0
    }  else missNA = F

    iter = 1
    p_old = rep(0, ncol(X))
    #Initiate the scores with the variable with the highest variance when there are no NAs with the one with least NAs instead
    if(missNA){
      t_old = X[,1,drop=FALSE]
      t_old[is.na(t_old)] = 0
    } else t_old = X[,which.max(apply(X,2,var))[[1]],drop=FALSE]

    p_new = if(missNA) (t(X_sinNA) %*% t_old) / (t(C) %*% t_old^2)  else (t(X)%*%t_old) / drop(t(t_old)%*%t_old)

    #Normalize p_new to unit length
    p_new = p_new / sqrt(drop(crossprod(p_new)))

    t_new = if(missNA) (X_sinNA %*% p_new) / C %*% p_new^2   else X %*% p_new

    while (sqrt(drop(crossprod(p_new-p_old)))>1e-6 && iter<100) {
      #Update
      t_old = t_new
      p_old = p_new
      iter = iter + 1

      #Recalculate T and P
      p_new = if(missNA) (t(X_sinNA) %*% t_old) / (t(C) %*% t_old^2) else (t(X)%*%t_old) / drop(t(t_old)%*%t_old)
      #Normalize p_new to unit length
      p_new = p_new / sqrt(drop(crossprod(p_new)))
      t_new = if(missNA) (X_sinNA %*% p_new) / C %*% p_new^2   else X %*% p_new
    }

    return(list(scores = t_new, loadings = p_new))
  }

  block_weight = matrix(0,nrow = length(X),ncol =ncomp )
  super_scores = matrix(0, nrow = nrow(X[[1]]), ncol = ncomp )

  for (i in 1:ncomp){

    temp= lapply(X, function(x) nipals_comp(x))
    T_scores = do.call(cbind, lapply(names(temp), function(x) temp[[x]]$scores))
    if (i == 1) {
      block_scores = lapply(temp, function(x) x$scores)
      block_loadings = lapply(temp, function(x) x$loadings)
    }else{
      block_scores = lapply(names(temp), function(x) cbind(block_scores[[x]], temp[[x]]$scores))
      block_loadings = lapply(names(temp), function(x) cbind(block_loadings[[x]], temp[[x]]$loadings))
      names(block_scores) = names(block_loadings) = b_names
    }
    temp = nipals_comp(T_scores)
    w = t(T_scores) %*% temp$scores
    block_weight[,i] = w / sqrt(drop(crossprod(w)))

    super_scores[,i] = T_scores %*% block_weight[,i,drop=FALSE]

    X = lapply(b_names, function(x) X[[x]]- block_scores[[x]][,i,drop=FALSE] %*% t(block_loadings[[x]][,i,drop=FALSE]) )
    names(X) = b_names
  }

  #Change the colnames and save the rownames

  block_scores = lapply(block_scores, function(x) {
    colnames(x) = paste0("p", 1:ncomp)
    rownames(x) = rownames(X[[1]])
    return(x)
    })

  block_loadings = lapply(names(block_loadings), function(x) {
    colnames(block_loadings[[x]]) = paste0("p", 1:ncomp)
    rownames(block_loadings[[x]]) = colnames(X[[x]])
    return(block_loadings[[x]])
  })
  names(block_loadings) = b_names

  colnames(block_weight) = colnames(super_scores) = paste0("p", 1:ncomp)
  rownames(block_weight) = b_names
  rownames(super_scores) = rownames(X[[1]])

  return(list(block_scores=block_scores, block_loadings = block_loadings, block_weight= block_weight, super_scores = super_scores))
}


#An starting global score is taken which will be used for each block

nipals_mbpca = function(X, ncomp = NULL ){

  b_names = names(X)

  if(is.null(ncomp)) ncomp = min(sapply(X, function(x) min(nrow(x)-1, ncol(x))))

  block_weight = matrix(0,nrow = length(X),ncol =ncomp )
  super_scores = matrix(0, nrow = nrow(X[[1]]), ncol = ncomp )
  super_loadings = matrix(0, nrow = length(X), ncol = ncomp )

  for (i in 1:ncomp){

    iter = 1
    w_old = rep(0, length(X))

    #Choose an arbitrary starting global score
    rand = X[[sample(length(X), 1)]]
    super_t_old = rand[, sample(ncol(rand), 1), drop=FALSE]

    block_p = setNames(lapply(b_names, function(x) (t(X[[x]])%*%super_t_old) / drop(t(super_t_old)%*%super_t_old)), b_names)
    block_p = setNames(lapply(b_names, function(x) block_p[[x]] / sqrt(drop(crossprod(block_p[[x]])))), b_names)
    block_t = setNames(lapply(b_names, function(x) X[[x]] %*% block_p[[x]]), b_names)

    T_scores = do.call(cbind, block_t)
    w_new = (t(T_scores) %*% super_t_old) / drop(t(super_t_old)%*%super_t_old)
    w_new = w_new / sqrt(drop(crossprod(w_new)))

    super_t_new = T_scores %*% w_new

    while(sqrt(drop(crossprod(w_new-w_old)))>1e-6 && iter<100){

      #Update
      super_t_old = super_t_new
      w_old = w_new
      iter = iter + 1

      #Recalculate block_scores, loadings, super_scores and loadings
      block_p = setNames(lapply(b_names, function(x) (t(X[[x]])%*%super_t_old) / drop(t(super_t_old)%*%super_t_old)), b_names)
      block_p = setNames(lapply(b_names, function(x) block_p[[x]] / sqrt(drop(crossprod(block_p[[x]])))), b_names)
      block_t = setNames(lapply(b_names, function(x) X[[x]] %*% block_p[[x]]), b_names)

      T_scores = do.call(cbind, block_t)
      w_new = (t(T_scores) %*% super_t_old) / drop(t(super_t_old)%*%super_t_old)
      w_new = w_new / sqrt(drop(crossprod(w_new)))

      super_t_new = T_scores %*% w_new
    }

    if (i==1){
      block_scores = block_t
      block_loadings = block_p
    } else{
      block_scores = setNames(lapply(b_names, function(x) cbind(block_scores[[x]], block_t[[x]])),b_names)
      block_loadings = setNames(lapply(b_names, function(x) cbind(block_loadings[[x]], block_p[[x]])),b_names)
    }

    super_scores[,i] = super_t_new
    super_loadings[,i] = w_new

    X = setNames(lapply(b_names, function(x) X[[x]]- block_t[[x]] %*% t(block_p[[x]]) ),b_names)

  }

  #Change the colnames and save the rownames
  block_scores = lapply(block_scores, function(x) {
    colnames(x) = paste0("p", 1:ncomp)
    rownames(x) = rownames(X[[1]])
    return(x)
  })

  block_loadings = lapply(names(block_loadings), function(x) {
    colnames(block_loadings[[x]]) = paste0("p", 1:ncomp)
    rownames(block_loadings[[x]]) = colnames(X[[x]])
    return(block_loadings[[x]])
  })
  names(block_loadings) = b_names

  colnames(super_loadings) = colnames(super_scores) = paste0("p", 1:ncomp)
  rownames(super_loadings) = b_names
  rownames(super_scores) = rownames(X[[1]])

  return(list(block_scores=block_scores, block_loadings = block_loadings, super_scores = super_scores,super_loadings= super_loadings))
}

