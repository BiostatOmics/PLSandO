project.obs.nipals = function(x, newObs, comp){

  #See which are the observations with NAs to use NIPALS instead of XP
  NArows = which(rowSums(is.na(newObs))>0)

  #Scores
  scores_new = (as.matrix(newObs) %*% x$loadings)[,comp]

  newObs_NA = newObs[NArows,,drop=FALSE]
  C = matrix(1, ncol = ncol(newObs_NA), nrow = nrow(newObs_NA) )
  C[is.na(newObs_NA)] = 0
  newObs_NA[is.na(newObs_NA)] = 0

  scores_NA = (((C * as.matrix(newObs_NA)) %*% x$loadings) / (C %*% x$loadings^2))[,comp]
  scores_new[NArows,] = scores_NA

  return(scores_new)

}

dummytovariable<-function(mat,name){

  var = matrix(0,nrow = nrow(mat),ncol = 1)
  colnames(var) = name

  for (i in 1:ncol(mat)){
    var[which(mat[,i]==max(mat[,i]))] = gsub(paste0(name,'_'), '',colnames(mat)[i])
  }

  var = as.factor(var)
  return(var)
}


