#NIPALS algorithm for PCA

#Me faltaría meter los casos en los que hay valores faltantes

nipals_pca = function(X, ncomp = NULL ){

  X = as.matrix(X)

  if(any(is.na(X))){
    missNA = T
    X_sinNA = X
    X_sinNA[is.na(X)]= 0
    C_obs = as.integer(complete.cases(X))
    C_vars = as.integer(complete.cases(t(X)))
  }  else missNA = F

  if(is.null(ncomp)){
    ncomp = min(nrow(X)-1, ncol(X))
  }

  scores = matrix(0,nrow = nrow(X),ncol =ncomp )
  loadings = matrix(0, nrow = ncol(X), ncol = ncomp )
  eigen = rep(0, ncomp)

  for (i in 1:ncomp) {
    iter = 1
    p_old = rep(0, ncol(X))
    #Initiate the scores with the variable with the highest variance when there are no NAs with the one with least NAs instead
    if(missNA){
      t_old = X[,1,drop=FALSE]
      t_old[is.na(t_old)] = 0
    } else t_old = X[,which.max(apply(X,2,var))[[1]],drop=FALSE]

    p_new = if(missNA) (t(X_sinNA) %*% t_old) / sum(C_obs * t_old^2 ) else (t(X)%*%t_old) / drop(t(t_old)%*%t_old)

    #Normalize p_new to unit length
    p_new = p_new / sqrt(drop(crossprod(p_new)))

    t_new = if(missNA) (X_sinNA %*% p_new) / sum(C_vars * p_new^2 )  else X %*% p_new

    while (sqrt(drop(crossprod(p_new-p_old)))>1e-6 && iter<100) {
      #Update
      t_old = t_new
      p_old = p_new
      iter = iter + 1

      #Recalculate T and P
      p_new = if(missNA) (t(X_sinNA) %*% t_old) / sum(C_obs * t_old^2 ) else (t(X)%*%t_old) / drop(t(t_old)%*%t_old)
      #Normalize p_new to unit length
      p_new = p_new / sqrt(drop(crossprod(p_new)))
      t_new = if(missNA) (X_sinNA %*% p_new) / sum(C_vars * p_new^2 )  else X %*% p_new
    }
    loadings[,i] = p_new
    scores[,i] = t_new
    eigen[i] = t(t_new)%*%t_new / (nrow(X)-1)

    X = X - t_new%*%t(p_new)

    if(missNA){
      X_sinNA = X
      X_sinNA[is.na(X)]= 0
    }

  }
  rownames(loadings) = colnames(X)
  rownames(scores) = rownames(X)
  colnames(loadings) = colnames(scores) = paste0('p',1:ncomp)

  return(list(scores=scores, loadings = loadings, eigen = eigen))
}

svd_pca = function(X, ncomp = NULL){
  X = as.matrix(X)

  if(is.null(ncomp)){
    ncomp = min(nrow(X)-1, ncol(X))
  }

  temp = svd(X, nu = ncomp, nv = ncomp)
  eigen = (temp$d^2 / (nrow(X)-1)) [1:ncomp]
  scores = temp$u %*% diag(temp$d[1:ncomp])
  loadings = temp$v

  rownames(loadings) = colnames(X)
  rownames(scores) = rownames(X)
  colnames(loadings) = colnames(scores) = paste0('p',1:ncomp)

  return(list(scores=scores, loadings = loadings, eigen = eigen))
}

nipals_pls = function(X, Y, ncomp = NULL ){

  X = as.matrix(X)
  Y = as.matrix(Y)

  if(any(is.na(X))||any(is.na(Y))){
    missNA =  T
    X_sinNA = X
    X_sinNA[is.na(X)]= 0
    C = matrix(1, ncol = ncol(X), nrow = nrow(X) )
    C[is.na(X)] = 0
    if(any(is.na(Y))) missNAY = T else missNAY = F
    Y_sinNA = Y
    Y_sinNA[is.na(Y)]= 0
    CY = matrix(1, ncol = ncol(Y), nrow = nrow(Y) )
    CY[is.na(Y)] = 0
  }  else missNA = F

  if(is.null(ncomp)){
    ncomp = min(nrow(X)-1, ncol(X))
  }

  scores = matrix(0,nrow = nrow(X),ncol =ncomp )
  loadings = matrix(0, nrow = ncol(X), ncol = ncomp )
  scoresY = matrix(0,nrow = nrow(X),ncol =ncomp )
  loadingsY = matrix(0, nrow = ncol(Y), ncol = ncomp )
  weights = matrix(0, nrow = ncol(X), ncol = ncomp )

  for (i in 1:ncomp) {
    iter = 1
    #Initiate the scores with the variable with the highest variance when there are no NAs with the one with least NAs instead
    if(missNAY){
      u_old = Y[,1,drop=FALSE]
      u_old[is.na(u_old)] = 0
    } else u_old = Y[,which.max(apply(Y,2,var))[[1]],drop=FALSE]

    w_new = if(missNA) t(t(u_old) %*% X_sinNA / drop(t(CY) %*% u_old^2)) else t(t(u_old)%*%X / drop(t(u_old)%*%u_old))
    w_new = w_new / sqrt(drop(crossprod(w_new)))

    t_new = if(missNA) (X_sinNA %*% w_new) / (C %*% w_new^2)  else X %*% w_new

    c_new = if(missNA) t((t(t_new)%*%Y_sinNA) / (t(CY) %*% t_new^2))  else t((t(t_new)%*%Y)/ drop(t(t_new)%*%t_new))

    u_new = if(missNA) if(ncol(CY)==1) (Y_sinNA %*% c_new) / drop(t(c_new)%*%c_new) else (Y_sinNA %*% c_new) / (CY %*% c_new^2)  else (Y %*% c_new) / drop(t(c_new)%*%c_new)

    p_new = if(missNA) t((t(t_new)%*%X_sinNA)) / (t(C) %*% t_new^2)  else  t((t(t_new)%*%X) / drop(t(t_new)%*%t_new))

    while (sqrt(drop(crossprod(u_new-u_old)))>1e-6 && iter<100) {
      #Update
      t_old = t_new
      p_old = p_new
      c_old = c_new
      u_old = u_new
      iter = iter + 1

      #Recalculate T, P, W, U and C
      w_new = if(missNA) t(t(u_old) %*% X_sinNA / drop(t(CY) %*% u_old^2)) else t(t(u_old)%*%X / drop(t(u_old)%*%u_old))
      w_new = w_new / sqrt(drop(crossprod(w_new)))

      t_new = if(missNA) (X_sinNA %*% w_new) / (C %*% w_new^2)  else X %*% w_new

      c_new = if(missNA) t((t(t_new)%*%Y_sinNA) / (t(CY) %*% t_new^2))  else t((t(t_new)%*%Y)/ drop(t(t_new)%*%t_new))

      u_new = if(missNA) if(ncol(CY)==1) (Y_sinNA %*% c_new) / drop(t(c_new)%*%c_new) else (Y_sinNA %*% c_new) / (CY %*% c_new^2)  else (Y %*% c_new) / drop(t(c_new)%*%c_new)

      p_new = if(missNA) t((t(t_new)%*%X_sinNA)) / (t(C) %*% t_new^2)  else  t((t(t_new)%*%X) / drop(t(t_new)%*%t_new))

    }
    loadings[,i] = p_new
    scores[,i] = t_new
    loadingsY[,i] = c_new
    scoresY[,i] = u_new
    weights[,i] = w_new

    X = X - t_new%*%t(p_new)
    Y = Y - t_new%*%t(c_new)

    if(missNA){
      X_sinNA = X
      X_sinNA[is.na(X)]= 0
      Y_sinNA = Y
      Y_sinNA[is.na(Y)]= 0
    }

  }

  weightsStar = weights%*%solve(t(loadings)%*%weights)

  coefficients = weightsStar %*% t(loadingsY)

  rownames(loadings) = rownames(weights) = rownames(weightsStar) = rownames(coefficients) = colnames(X)
  rownames(loadingsY) = colnames(coefficients) = colnames(Y)
  rownames(scores) = rownames(scoresY) = rownames(X)
  colnames(loadings) = colnames(scores)= colnames(scoresY)= colnames(loadingsY)= colnames(weights) = colnames(weightsStar) = paste0('p',1:ncomp)

  return(list(scores=scores, loadings = loadings, scoresY=scoresY, loadingsY = loadingsY, weights = weights, weightsStar = weightsStar, coefficients = coefficients ))
}

pls_cross = function(X, Y, scaling, scalingY, ncomp = NULL, folds = 5, rep = 10, parallel = T){

  ## TO DO: Lo limitamos a un número máximo de componentes? En ropls está fijado a 10.
  if(is.null(ncomp)){
    ncomp = min(nrow(X)-1, ncol(X))
  }

  if(nrow(X)<=5){
    warning("Low number of replicates. Leave-one-out cv will be performed.")
    method = 'loo'
  } else method = 'kfold'

  message("\n Running optimization:")


  options(future.globals.maxSize = 4000*1024^2)
  seed = 1:rep
  if(!isFALSE(parallel)){
    if(is.numeric(parallel)){
      if(.Platform$OS.type == "unix") {
        future::plan("multicore", workers = parallel)
      }else{
        future::plan("multisession", workers = parallel)
      }
    } else{
      nc = future::availableCores() - 1
      if(.Platform$OS.type == "unix") {
        future::plan("multicore", workers = nc)
      }else{
        future::plan("multisession", workers = nc)
      }
      parallel =nc
    }
    crossVal_res = furrr::future_map(1:rep,
                              ~crossVal(.x, X, Y, ncomp, folds, scaling, scalingY, seed[.x], method),
                                           .progress = TRUE,.options = furrr::furrr_options(seed = TRUE) )
  } else{
    crossVal_res = purrr::map(1:rep,
                       ~crossVal(.x, X, Y, ncomp, folds, scaling, scalingY, seed[.x], method),
                                    .progress = TRUE,.options = furrr::furrr_options(seed = TRUE) )
  }

  return(crossVal_res)

}

createFold = function(X, k, seed = NULL){

  if(!is.null(seed)) set.seed(seed)

  n = nrow(X)

  index = sample(n)

  folds = vector('list', k)
  for (i in 1:n) {
    fold_index = ((i-1)%%k) +1
    folds[[fold_index]] = c(folds[[fold_index]], index[i])
  }

  return(folds)
}

crossVal = function(iter, X, Y, ncomp, k = 5, scaling, scalingY, seed, method){

  if(method=='loo') k = nrow(X)

  folds = createFold(X, k, seed)

  R2 = matrix(0, length(folds), ncomp)
  PRESS = matrix(0, length(folds),ncomp)

  for (i in 1:length(folds)){

    ## Scaling X

    if(class(X)!='list' && scaling %in% c('softBlock','hardBlock')) blocks = rep(1, times = ncol(X)) else blocks = NULL

    if (class(X)=='list') {
      if (!scaling %in% c("softBlock", "hardBlock")) warning('When blocks are considered we recommend using either softBlock or hardBlock scaling')
      if (length(unique(sapply(X, nrow)))!=1) return(stop('All blocks must have the same observations'))
      blocks = rep(seq_along(X), times = sapply(x, nrow) )
      X = do.call(cbind, X)
    }

    Xfold = X[-folds[[i]],,drop=FALSE]
    Yfold = Y[-folds[[i]],,drop=FALSE]

    if (scaling != 'none') {
      escalado = Scaling(Xfold, scaling= scaling, blocks = blocks)
      Xfold = escalado$x
      centrado = escalado$centering
      escalado = escalado$scaling
      Xval = sweep(X[folds[[i]],,drop=FALSE], 2, centrado, FUN = "-")
      Xval = sweep(Xval, 2, escalado, FUN = "/")
    } else{
      escalado = rep(1, times = ncol(Xfold))
      centrado = rep(0, times = ncol(Xfold))
      Xval = X[folds[[i]],,drop=FALSE]
    }

    ## Scaling Y

    if (scalingY != 'none') {
      escaladoY = Scaling(Yfold, scaling= scalingY, blocks = NULL)
      Yfold = escaladoY$x
      centradoY = escaladoY$centering
      escaladoY = escaladoY$scaling
      Yval = sweep(Y[folds[[i]],,drop=FALSE], 2, centradoY, FUN = "-")
