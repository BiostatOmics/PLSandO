#x result from runing PCA
fromSuperToLow = function(x){

  #Mientras que no sea none hay que aplicar el escalado estandar  a los bloques. Aquí.

  load_block = replicate(length(x$input$X), matrix(0, nrow = ncol(x$input$X), ncol = x$ncomp), simplify = FALSE)
  score_block = replicate(length(x$input$X), matrix(0, nrow = nrow(x$input$X), ncol = x$ncomp), simplify = FALSE)
  error_block = list()
  expl.var = vector()

  nvarBlock = rep(1, times=length(x$input$X))
  if(x$input$scalingType=='softBlock'){
    nvarBlock = vapply(x$input$X, function(x) ncol(x)^0.25)
  } else if (x$input$scalingType=='hardBlock'){
    nvarBlock = vapply(x$input$X, function(x) sqrt(ncol(x)))
  }

  for (c in 1:x$ncomp){
    for (i in 1:length(x$input$X)) {
      load_block[[i]][,c] = (x$input$X[[c]] %*% x$scores[,c]) / (t(x$scores[,c])%*%x$scores[,c])
      #Is load_block[[i]][,c] normalized?
      score_block[[i]][,c]  = (x$input$X[[c]] %*% load_block[[i]][,c]) / nvarBlock[c]
    }
    T_con = do.call(cbind, lapply(load_block, function(x) x[,c,drop=FALSE]))
    weight_super = (t(T_con) %*% x$scores[,c]) / (t(x$scores[,c])%*%x$scores[,c])
  }

  #Calcular los residuos para cada uno de los bloques
  for (i in 1:length(x$input$X)){
    error_block[[i]] = x$input$X[[i]] - (x$scores %*% t(load_block[[i]]))
    expl.var[i] = (1 - trace(t(error_block[[i]])%*%error_block[[i]])/trace(t(x$input$X[[i]])%*% x$input$X[[i]]))*100
  }

  return(expl.var)
}

