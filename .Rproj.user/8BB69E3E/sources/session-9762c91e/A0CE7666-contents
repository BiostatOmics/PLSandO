# Plots scores for observations of a ropls object.
# Can colour the observation by an external variable. Factor or numeric
# Can highlight the scores of the observations indicated (Useful to visualize for example observations that have been detected as outliers by some metric like T2-Hot or RSS)
# The plot can be done for selected axes

plotscores <- function(obj, axes = c(1, 2), colorBy = NULL, labels = FALSE, highlight = NULL) {

  # Create the base data frame
  scores_df <- data.frame(
    x = obj$scores[, axes[1]],
    y = obj$scores[, axes[2]],
    Labels = row.names(obj$scores)
  )

  if (!is.null(colorBy)) {

    if(class(colorBy)=='numeric'){
      num = TRUE
    } else {
      num = FALSE
    }
    scores_df$colorBy = colorBy
  }

  if(!is.null(highlight)){
    high_v = rep('Not', nrow(scores_df))
    high_v[highlight] = 'Highl'
    scores_df$highlight = high_v
  }

  # Create the plot
  ggp <- ggplot(scores_df, aes(x = x, y = y)) +
    geom_point(shape = 18, size = 3) +  # Plot points
    geom_hline(yintercept = 0, linetype = "dashed") +  # Horizontal dashed line
    geom_vline(xintercept = 0, linetype = "dashed") +  # Vertical dashed line
    coord_fixed(ratio = 1) +  # Maintain 1:1 aspect ratio and x-limits
    theme_minimal() +
    theme(legend.position = "bottom") +
    labs(title = "Scores", x = paste0('Comp', axes[1], ' (', round(obj$explVar[axes[1],'percVar'],2), '%)'),
         y = paste0('Comp', axes[2], ' (', round(obj$explVar[axes[2],'percVar'],2), '%)'))

  # Conditional layers based on arguments
  if (!is.null(colorBy)) {
    if(num){
      ggp <- ggp +
        aes(color = colorBy) +
        scale_color_gradient(low = "blue", high = "red",
                            name = "",
                            limits = c(min(colorBy), max(colorBy)),
                            breaks = pretty(range(colorBy), n = 5))+
        theme(legend.position = "right")

    } else{
      ggp <- ggp +
        aes(color = colorBy, fill = colorBy) +
        scale_fill_manual(values = scales::hue_pal()(length(unique(scores_df$colorBy)))) +
        scale_color_manual(values = scales::hue_pal()(length(unique(scores_df$colorBy)))) +
        stat_ellipse(aes(group = colorBy, fill = colorBy), type = "norm", level = 0.95, geom = "polygon", alpha = 0.2)
    }

  }

  if(!is.null(highlight)){
    ggp <-ggp +
      geom_point(data = subset(scores_df, highlight == "Highl"),
                 shape = 21, size = 5, color = "red")
  }

  if (labels) {
    ggp <- ggp +
      geom_text(aes(label = Labels), size = 3, angle = 60, hjust = 1, vjust = 1)  # Add labels
  }

  return(ggp)
}




# Para que funcione habría que meter como salida la matriz de daots escalada

R2varcomp <- function(obj) {

  X = obj$X
  SCT = colSums(X**2)
  mat = NULL

  # Loop through components and calculate cumulative R2 for each
  for (i in 1:obj$ncomp) {
    Loadings = obj$loadings[,1:i, drop=FALSE]
    Scores = obj$scores[,1:i, drop=FALSE]
    Xest = Scores %*% t(Loadings)
    SCE = colSums(Xest**2)
    R2 = SCE / SCT
    mat = rbind(mat, R2)
  }

  mat1 = mat

  # Calculate incremental R2 for each component
  if (nrow(mat1) > 1) {
    for (i in 2:nrow(mat1)) {
      mat1[i, ] = mat[i, ] - mat[i - 1, ]
    }
  }

  components = rownames(mat1) = as.character(1:obj$ncomp)
  variables = colnames(mat1)

  component_vec = rep(components, each = length(variables))
  variable_vec = rep(variables, times = length(components))
  R2_vec = as.vector(t(mat1))

  plot_df = data.frame(
    Component = component_vec,
    Variable = variable_vec,
    R2 = R2_vec)

  ggp = ggplot(plot_df, aes(x = Variable, y = R2, fill = Component)) +
    geom_col(position = "stack") +  # or just geom_col()
    scale_fill_brewer(palette = "Set3") +
    theme_minimal() +
    labs(title = "Explained R² per Variable in Component",
         x = "Variable",
         y = "Explained R²",
         fill = "NComp") +
    theme(axis.text.x = element_text(angle = 45, hjust = 1),
          legend.position = "right")

  return(ggp)
}

project.obs.nipalsmb = function(x, newObs, comp){

  #para el número de componentes que haya

  b_names = names(x$X)

  super_scores = matrix(0, nrow = nrow(newObs[[1]]), ncol = comp )

  for (i in 1:comp){

    block_scores = setNames(lapply(b_names, function(y) as.matrix(newObs[[y]])%*%x$block_loadings[[y]][,i,drop=FALSE]),b_names)

    T_scores = do.call(cbind, block_scores)

    super_t_new = T_scores %*% x$global_loadings[,i,drop = FALSE]

    super_scores[,i] = super_t_new

    newObs = setNames(lapply(b_names, function(y) newObs[[y]]- block_scores[[y]] %*% t(x$block_loadings[[y]][,i,drop=FALSE]) ),b_names)
  }

  colnames(super_scores) = paste0('p',1:comp)
  return(super_scores)

}


