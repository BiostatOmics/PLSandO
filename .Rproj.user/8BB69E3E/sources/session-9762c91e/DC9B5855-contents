
library(pls)

data(gasoline)

gasTrain <- gasoline[1:50,]
gasTest <- gasoline[51:60,]

# PLS models ----

gas1 = plsr(octane ~ NIR, ncomp = 10, data = gasTrain, validation = "LOO")

summary(gas1)
RMSEP(gas1)

gas2 = plsr(octane ~ NIR,  data = gasTrain, validation = "LOO")
selectNcomp(gas2)

explvar(gas1)

gas.cv = crossval(gas1)
plot(MSEP(gas.cv))

#Predict new data

drop(predict(gas1, ncomp = 1:2, newdata = gasTest))
predplot(gas1,ncomp =2,newdata =gasTest,asp =1,line=TRUE)

