resultsf1acu$met[which(resultsf1acu$met=='GLM-COR+EN')] = 'MLR+EN-MF'

res = resultsf1acu
res$scale = as.character(res$scale)
res$scale[which(res$scale=='pareto')] = 'softBlock'
res$scale[which(res$scale=='block')] = 'hardBlock'
res$scale<-factor(res$scale,levels = c("auto", "softBlock","hardBlock"))

df_summary <- res %>%
  group_by(n, scale,thres) %>%
  summarise(
    mean_f1score = mean(f1score),
    sd_f1score = sd(f1score),  # Standard deviation
    n_obs = 12  # Number of observations for SEM calculation
  ) %>%
  mutate(
    se_f1score = sd_f1score / sqrt(n_obs),  # Standard error
    lower_ci = mean_f1score - 1.96 * se_f1score,  # Lower bound of 95% CI
    upper_ci = mean_f1score + 1.96 * se_f1score   # Upper bound of 95% CI
  )

