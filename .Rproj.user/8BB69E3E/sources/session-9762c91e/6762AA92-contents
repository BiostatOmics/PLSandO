
load('OVAdata.Rdata')

data.omics$miRNA = t(apply(data.omics$miRNA,1,as.numeric))
colnames(data.omics$miRNA) = colnames(data.omics$CNV)

#Expresión diferencial de los potential regulators
library(limma)
#CNV
mydesign = model.matrix(~0+edesign[,1])
colnames(mydesign)<-c('differentiated','immunoreactive','mesenchymal','proliferative')
rownames(mydesign)<-rownames(edesign)
fit <- lmFit(data.omics$CNV, mydesign)
cont.matrix<-makeContrasts(contrasts=
                             c('immunoreactive - differentiated',
                               'mesenchymal - differentiated',
                               'proliferative - differentiated'),
                           levels = mydesign)
contrast_fit <- contrasts.fit(fit, cont.matrix)
contrast_fit <- eBayes(contrast_fit)
results <- topTable(contrast_fit, adjust.method = "fdr", sort.by = "F", n = Inf)
data.omics$CNV <- data.omics$CNV[rownames(data.omics$CNV[which(results[,'P.Value'] < 0.05),]),]
#Methyl
fit <- lmFit(data.omics$Methyl, mydesign)
contrast_fit <- contrasts.fit(fit, cont.matrix)
contrast_fit <- eBayes(contrast_fit)
results <- topTable(contrast_fit, adjust.method = "fdr", sort.by = "F", n = Inf)
data.omics$Methyl <- data.omics$Methyl[rownames(data.omics$Methyl[which(results[,'P.Value'] < 0.05),]),]
#miRNA
fit <- lmFit(data.omics$miRNA, mydesign)
contrast_fit <- contrasts.fit(fit, cont.matrix)
contrast_fit <- eBayes(contrast_fit)
results <- topTable(contrast_fit, adjust.method = "fdr", sort.by = "F", n = Inf)
data.omics$miRNA <- data.omics$miRNA[rownames(data.omics$miRNA[which(results[,'P.Value'] < 0.05),]),]
#TF
fit <- lmFit(data.omics$TF, mydesign)
contrast_fit <- contrasts.fit(fit, cont.matrix)
contrast_fit <- eBayes(contrast_fit)
results <- topTable(contrast_fit, adjust.method = "fdr", sort.by = "F", n = Inf)
data.omics$TF <- data.omics$TF[rownames(data.omics$TF[which(results[,'P.Value'] < 0.05),]),]

